---
import Layout from '../../layouts/Layout.astro';
import PatientHeader from '../../components/Patient/PatientHeader.astro';
import PatientTabs from '../../components/Patient/PatientTabs.astro';
import { ROLES, checkRole } from '../../functions/checkRole';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.NUTRIOLOGO, ROLES.ENTRENADOR, ROLES.ADMINISTRADOR])) {
  return Astro.redirect('/403');
}

const { patientId } = Astro.params;
const activeTab = (Astro.url.searchParams.get('tab') as any) || 'citas';

// Mock Patient Data
const mockPatient = {
  id: Number(patientId),
  firstName: 'Juan',
  lastName: 'Pérez',
  age: 21,
  bloodType: 'O+',
  allergies: 'Ninguna',
  weight: 72.5,
  height: 178,
  isAthlete: 1,
  gender: 'M',
  schoolLevel: 'Universidad'
};

// Mock Items based on selected tab
const mockItems = {
  citas: [
    { id: 1, date: '15/03/2026', time: '10:00 AM', doctor: 'Dra. Silva', status: 'Completada' },
    { id: 2, date: '22/04/2026', time: '11:30 AM', doctor: 'Dr. Gómez', status: 'Pendiente' },
  ],
  consultas: [
    { id: 1, date: '15/03/2026', diagnosis: 'Faringitis aguda', doctor: 'Dra. Silva', recipes: 1 }
  ],
  recetas: [
    { id: 1, date: '15/03/2026', medication: 'Amoxicilina 500mg', instructions: 'Tomar cada 8h por 7 días' }
  ],
  lesiones: [
    { id: 1, date: '10/02/2026', type: 'Esguince', zone: 'Tobillo derecho', status: 'Recuperada', severity: 'Leve' }
  ]
};
---

<Layout title={`Expediente: ${mockPatient.firstName}`}>
  <div class="mb-6">
    <div class="flex items-center gap-3 text-sm font-semibold text-slate-500 mb-2">
      <a href="/patients" class="hover:text-teal-600 transition-colors">Pacientes</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-teal-700">Expediente {mockPatient.id.toString().padStart(4, '0')}</span>
    </div>
  </div>

  <PatientHeader patient={mockPatient} />
  
  <PatientTabs patientId={patientId as string} activeTab={activeTab} />

  <!-- Render content based on activeTab -->
  <div class="glass-card rounded-2xl p-6">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-xl font-bold text-slate-800 capitalize">{activeTab}</h3>
      {user?.roleId === ROLES.DOCTOR && (
        <a href={`/${activeTab}/add?patientId=${patientId}`} class="bg-teal-50 text-teal-700 font-semibold py-2 px-4 rounded-xl border border-teal-200 hover:bg-teal-100 transition-colors flex items-center gap-2 text-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          Nuevo Registro
        </a>
      )}
    </div>

    {activeTab === 'citas' && (
      <div class="space-y-3">
        {mockItems.citas.map(c => (
          <div class="flex items-center justify-between p-4 bg-white/50 border border-slate-200/60 rounded-xl hover:bg-white/80 transition-colors">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-sky-50 text-sky-700 rounded-xl flex items-center justify-center shadow-sm border border-sky-100">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
              </div>
              <div>
                <p class="font-bold text-slate-800">{c.date} • {c.time}</p>
                <p class="text-sm text-slate-500">Con {c.doctor}</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class={`px-3 py-1 rounded-full text-xs font-semibold ${c.status === 'Completada' ? 'bg-emerald-50 text-emerald-700 border border-emerald-200' : 'bg-amber-50 text-amber-700 border border-amber-200'}`}>
                {c.status}
              </span>
              <button class="text-teal-600 hover:text-teal-800 text-sm font-semibold">Gestionar &rarr;</button>
            </div>
          </div>
        ))}
      </div>
    )}

    {activeTab === 'lesiones' && (
      <div class="space-y-3">
        {mockItems.lesiones.map(l => (
          <div class="flex items-center justify-between p-4 bg-white/50 border border-slate-200/60 rounded-xl hover:bg-white/80 transition-colors">
            <div class="flex items-center gap-4">
              <div class={`w-12 h-12 rounded-xl flex items-center justify-center shadow-sm border ${l.severity === 'Leve' ? 'bg-amber-50 text-amber-600 border-amber-200' : 'bg-rose-50 text-rose-600 border-rose-200'}`}>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m14.5 4-5 5"/><path d="m14.5 9.5-5 5"/><path d="m14.5 15-5 5"/></svg>
              </div>
              <div>
                <p class="font-bold text-slate-800">{l.type} - {l.zone}</p>
                <p class="text-sm text-slate-500">{l.date}</p>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <span class="px-3 py-1 rounded-full text-xs font-semibold bg-emerald-50 text-emerald-700 border border-emerald-200">
                {l.status}
              </span>
              <button class="text-teal-600 hover:text-teal-800 text-sm font-semibold">Detalles &rarr;</button>
            </div>
          </div>
        ))}
        {mockItems.lesiones.length === 0 && <p class="text-slate-500 text-center py-6">No hay lesiones registradas.</p>}
      </div>
    )}

    {/* Fallback for other tabs */}
    {(activeTab !== 'citas' && activeTab !== 'lesiones') && (
       <div class="text-center py-12 text-slate-500 border border-dashed border-slate-300 rounded-xl bg-white/30">
        <p>Listado de {activeTab} para el paciente</p>
      </div>
    )}
  </div>
</Layout>
