---
/**
 * COMPONENTE SIDEBAR (Navegación Lateral)
 * Este componente genera el menú de navegación principal del sistema.
 * Es altamente dinámico y utiliza el sistema RBAC para ocultar o mostrar
 * módulos según el rol del usuario logueado.
 */
import SideBarLink from "./SideBarLink.astro";
import { ROLES, checkRole } from "../../../functions/checkRole";
import type { SessionUser } from "../../../functions/getSession";

interface Props {
  user: SessionUser | null; // Usuario actual de la sesión
  currentPath: string; // Ruta actual para marcar el enlace activo
}

const { user, currentPath } = Astro.props;

// Diccionario de íconos SVG reutilizables para el menú
const ICONS = {
  dashboard:
    '<rect width="7" height="9" x="3" y="3" rx="1"/><rect width="7" height="5" x="14" y="3" rx="1"/><rect width="7" height="9" x="14" y="12" rx="1"/><rect width="7" height="5" x="3" y="16" rx="1"/>',
  patients:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  appointments:
    '<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/><path d="M8 18h.01"/><path d="M12 18h.01"/><path d="M16 18h.01"/>',
  injuries:
    '<path d="M12 2v20"/><path d="m14.5 4-5 5"/><path d="m14.5 9.5-5 5"/><path d="m14.5 15-5 5"/>',
  inventory:
    '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" x2="12" y1="22.08" y2="12"/>',
  nutrition:
    '<path d="M12 22a9 9 0 0 0 9-9c0-4.97-4-9-9-9s-9 4.03-9 9a9 9 0 0 0 9 9Z"/><path d="M12 14c-1.66 0-3-1.34-3-3v0c0-1.66 1.34-3 3-3v0c1.66 0 3 1.34 3 3v0c0 1.66-1.34 3-3 3Z"/><path d="M12 2v2M2 12h2M20 12h2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M17.66 6.34l1.41-1.41M4.93 19.07l1.41-1.41"/>',
  notes:
    '<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>',
  users:
    '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/>',
  reports: '<path d="M3 3v18h18"/><path d="m19 9-5 5-4-4-3 3"/>',
  logout:
    '<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/>',
  medical: '<path d="M22 12h-4l-3 9L9 3l-3 9H2"/>',
  availability: '<rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/>',
};

/**
 * CONFIGURACIÓN DE LINKS
 * Cada link define:
 * - href: La ruta destino.
 * - label: El texto a mostrar.
 * - icon: El ícono SVG asociado.
 * - roles: Lista de IDs de roles que tienen permiso para ver este enlace.
 */
const links = [
  // Dashboard principal - El Staff y Estudiante tienen sus propias redirecciones en index.astro
  {
    href: "/",
    label: "Dashboard",
    icon: ICONS.dashboard,
    roles: [
      ROLES.ADMINISTRADOR,
      ROLES.JEFE_MEDICO,
      ROLES.DOCTOR,
      ROLES.NUTRIOLOGO,
      ROLES.ENTRENADOR,
    ],
  },

  // Link especial para el Estudiante (Acceso directo a su perfil)
  {
    href: "/mi-perfil",
    label: "Mi Expediente",
    icon: ICONS.patients,
    roles: [ROLES.ESTUDIANTE],
  },

  // Módulo de Pacientes (Global)
  {
    href: "/patients",
    label: "Pacientes",
    icon: ICONS.patients,
    roles: [
      ROLES.DOCTOR,
      ROLES.JEFE_MEDICO,
      ROLES.ENTRENADOR,
      ROLES.ADMINISTRADOR,
      ROLES.NUTRIOLOGO,
    ],
  },

  {
    href: "/appointments",
    label: "Agenda",
    icon: ICONS.appointments,
    roles: [
      ROLES.DOCTOR,
      ROLES.JEFE_MEDICO,
      ROLES.ADMINISTRADOR,
      ROLES.NUTRIOLOGO,
    ],
  },

  {
    href: "/consultations",
    label: "Consultas",
    icon: ICONS.medical,
    roles: [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.ADMINISTRADOR],
  },

  {
    href: "/injuries",
    label: "Lesiones",
    icon: ICONS.injuries,
    roles: [
      ROLES.DOCTOR,
      ROLES.JEFE_MEDICO,
      ROLES.ADMINISTRADOR,
      ROLES.ENTRENADOR,
    ],
  },

  {
    href: "/medications",
    label: "Inventario",
    icon: ICONS.inventory,
    roles: [ROLES.STAFF, ROLES.ADMINISTRADOR],
  },

  {
    href: "/nutrition/profiles",
    label: "Nutrición",
    icon: ICONS.nutrition,
    roles: [ROLES.NUTRIOLOGO, ROLES.ADMINISTRADOR],
  },

  {
    href: "/notes",
    label: "Alertas y Notas",
    icon: ICONS.notes,
    roles: [
      ROLES.DOCTOR,
      ROLES.NUTRIOLOGO,
      ROLES.ENTRENADOR,
      ROLES.JEFE_MEDICO,
      ROLES.ADMINISTRADOR,
    ],
  },

  {
    href: "/reports",
    label: "Reportes",
    icon: ICONS.reports,
    roles: [ROLES.ADMINISTRADOR, ROLES.JEFE_MEDICO],
  },

  {
    href: "/users",
    label: "Usuarios",
    icon: ICONS.users,
    roles: [ROLES.JEFE_MEDICO, ROLES.ADMINISTRADOR],
  },

  {
    href: "/settings/availability",
    label: "Disponibilidad",
    icon: ICONS.availability,
    roles: [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.NUTRIOLOGO],
  },
];

// FILTRADO DINÁMICO: Solo mostramos los links que el usuario tiene permitido ver
const visibleLinks = links.filter((link) => {
  // Excepción extra: El admin tiene acceso global por checkRole, pero 'Mi Perfil' no aplica para su rol
  if (
    link.href === "/mi-perfil" &&
    Number(user?.roleId) === ROLES.ADMINISTRADOR
  )
    return false;
  return checkRole(user, link.roles);
});
---

<aside
  class="w-64 glass-strong shadow-2xl flex flex-col min-h-screen border-r border-white/40 z-20 sticky top-0"
>
  {/* Branding / Logo */}
  <div class="p-6 border-b border-white/30">
    <div class="flex items-center gap-3">
      <div
        class="w-12 h-12 flex items-center justify-center transition-transform hover:scale-110"
      >
        <img src="/logo.png" alt="MediMAD Logo" class="w-full h-full object-contain" />
      </div>
      <div>
        <h1
          class="text-xl font-extrabold bg-clip-text text-transparent bg-gradient-to-r from-teal-700 to-sky-700"
        >
          MediMAD
        </h1>
        <p
          class="text-[10px] uppercase font-bold text-slate-500 tracking-wider"
        >
          Sistema Médico
        </p>
      </div>
    </div>
  </div>

  {/* Lista de Navegación */}
  <nav class="flex-1 px-4 py-6 space-y-1.5 overflow-y-auto scrollbar-hide">
    {
      visibleLinks.map((link) => (
        <SideBarLink
          href={link.href}
          label={link.label}
          icon={link.icon}
          active={
            currentPath === link.href ||
            (link.href !== "/" && currentPath.startsWith(link.href))
          }
        />
      ))
    }
  </nav>

  {/* Sección de Usuario y Logout */}
  <div class="p-4 border-t border-white/30 mt-auto bg-white/20">
    <div class="flex items-center gap-3 px-2 py-2 mb-4">
      <div
        class="w-9 h-9 bg-teal-100 rounded-full flex items-center justify-center border border-teal-200 text-teal-800 font-bold capitalize"
      >
        {user?.firstName?.[0] || "U"}
      </div>
      <div class="overflow-hidden">
        <p class="text-sm font-semibold text-slate-800 truncate">
          {user?.firstName}
          {user?.lastName}
        </p>
        <p class="text-xs text-slate-500 truncate font-medium">Conectado</p>
      </div>
    </div>

    <a
      href="/api/auth/logout"
      class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-rose-600 hover:bg-rose-50 transition-colors bg-white/40 border border-white/60 shadow-sm font-medium text-sm w-full justify-center"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="w-4 h-4"
        set:html={ICONS.logout}
      />
      <span>Cerrar Sesión</span>
    </a>
  </div>
</aside>
