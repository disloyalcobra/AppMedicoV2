---
/**
 * FORMULARIO DE CITAS MÉDICAS (Actualizado con Slots Dinámicos)
 */
import { db } from '../../turso';
import { ROLES } from '../../functions/checkRole';

interface Props {
  appointment?: any; 
}

const { appointment } = Astro.props;

// 1. CARGA DE CATÁLOGOS
const user = Astro.locals.user;

// --- FILTRADO DE PACIENTES ---
let patientsQuery = `SELECT patientId, firstName, lastName FROM Patients JOIN Users ON Patients.patientId = Users.userId`;
let patientsArgs: any[] = [];

if (user?.roleId === ROLES.ENTRENADOR) {
  // El entrenador solo ve sus propios estudiantes asignados
  patientsQuery = `
    SELECT p.patientId, u.firstName, u.lastName 
    FROM Patients p 
    JOIN Users u ON p.patientId = u.userId 
    JOIN User_Patient up ON p.patientId = up.patientId
    WHERE up.userId = ? AND up.roleType = 'Coach'
  `;
  patientsArgs = [user.userId];
}

const patientsRes = await db.execute({ sql: patientsQuery, args: patientsArgs });
const patients = patientsRes.rows;

const url = Astro.url;
let lockedPatientId = url.searchParams.get('patientId');

if (user?.roleId === ROLES.ESTUDIANTE) {
  lockedPatientId = String(user.userId);
}

// --- FILTRADO DE ESPECIALISTAS ---
let doctorsQuery = `
  SELECT u.userId, u.firstName, u.lastName, r.roleName 
  FROM Users u 
  JOIN Roles r ON u.roleId = r.roleId 
  WHERE r.roleName IN ('Doctor', 'Jefe Médico', 'Nutriólogo', 'Fisioterapeuta')
`;

if (user?.roleId === ROLES.ENTRENADOR) {
  // El entrenador solo agenda con médicos
  doctorsQuery = `
    SELECT u.userId, u.firstName, u.lastName, r.roleName 
    FROM Users u 
    JOIN Roles r ON u.roleId = r.roleId 
    WHERE r.roleName IN ('Doctor', 'Jefe Médico')
  `;
}

const doctorsRes = await db.execute(doctorsQuery);
const doctors = doctorsRes.rows;

// Determinar si el especialista debe estar bloqueado (autoselección)
const isClinicalRole = [ROLES.DOCTOR, ROLES.NUTRIOLOGO, ROLES.FISIOTERAPEUTA].includes(Number(user?.roleId));
const lockedSpecialist = isClinicalRole ? doctors.find((d: any) => d.userId === user?.userId) : null;

---

<div id="appointmentFormContainer" class="space-y-6">
  <div id="formStatus" class="hidden"></div>

  <form id="appointmentForm" class="space-y-6">
    <div class="glass-card rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-800 mb-4 border-b border-white/60 pb-2">Datos de la Cita</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
        <div class="md:col-span-2">
          <label for="patientId" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Paciente</label>
          
          {lockedPatientId ? (
            <>
              <div class="w-full bg-slate-100 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 font-semibold shadow-sm cursor-not-allowed">
                {patients.find((p: any) => String(p.patientId) === lockedPatientId)?.firstName} {patients.find((p: any) => String(p.patientId) === lockedPatientId)?.lastName} (Exp. #{String(lockedPatientId).padStart(4, '0')})
              </div>
              <input type="hidden" name="patientId" id="patientId" value={lockedPatientId} />
            </>
          ) : (
            <select name="patientId" id="patientId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
              <option value="">Seleccionar Paciente</option>
              {patients.map((p: any) => (
                <option value={String(p.patientId)} selected={String(p.patientId) === String(lockedPatientId)}>{p.firstName} {p.lastName} (Exp. #{String(p.patientId).padStart(4, '0')})</option>
              ))}
            </select>
          )}
        </div>

        <div>
          <label for="doctorId" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Médico/Especialista</label>
          
          {lockedSpecialist ? (
            <>
              <div class="w-full bg-slate-100 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 font-semibold shadow-sm cursor-not-allowed">
                {lockedSpecialist.firstName} {lockedSpecialist.lastName} ({lockedSpecialist.roleName})
              </div>
              <input type="hidden" name="doctorId" id="doctorId" value={String(lockedSpecialist.userId)} />
            </>
          ) : (
            <select name="doctorId" id="doctorId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
              <option value="">Asignar Médico</option>
              {doctors.map((d: any) => (
                <option value={String(d.userId)} selected={user?.userId === d.userId}>{d.firstName} {d.lastName} ({d.roleName})</option>
              ))}
            </select>
          )}
        </div>

        <div>
          <label for="date" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Fecha</label>
          <input type="date" name="date" id="dateInput" min={new Date().toISOString().split('T')[0]} class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
        </div>

        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-slate-700 mb-2 ml-1">Horarios Disponibles</label>
          <div id="slotsContainer" class="grid grid-cols-4 sm:grid-cols-6 lg:grid-cols-8 gap-2 min-h-[50px] p-4 bg-slate-50/50 rounded-2xl border border-slate-100 italic text-slate-400 text-sm flex items-center justify-center text-center">
            Selecciona médico y fecha para ver horarios disponibles...
          </div>
          <input type="hidden" name="time" id="timeInput" required />
        </div>

        <div class="md:col-span-2">
          <label for="reason" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Motivo de la Cita</label>
          <textarea name="reason" id="reason" rows="3" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="Ej. Dolor lumbar persistente, revisión de análisis..." required></textarea>
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-4 border-t border-white/60">
        <button type="submit" id="submitBtn" class="bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-bold py-3 px-8 rounded-2xl shadow-lg hover:shadow-teal-500/20 transition-all flex items-center gap-2" disabled>
          Confirmar Cita
        </button>
      </div>
    </div>
  </form>
</div>

<script>
  const form = document.getElementById('appointmentForm') as HTMLFormElement;
  const doctorSelect = document.getElementById('doctorId') as HTMLSelectElement;
  const dateInput = document.getElementById('dateInput') as HTMLInputElement;
  const slotsContainer = document.getElementById('slotsContainer');
  const timeInput = document.getElementById('timeInput') as HTMLInputElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const formStatus = document.getElementById('formStatus');

  async function updateSlots() {
    const doctorId = doctorSelect.value;
    const date = dateInput.value;

    if (!doctorId || !date) {
      if (slotsContainer) slotsContainer.innerHTML = 'Selecciona médico y fecha para ver horarios disponibles...';
      submitBtn.disabled = true;
      return;
    }

    if (slotsContainer) {
      slotsContainer.innerHTML = '<div class="w-5 h-5 border-2 border-teal-500/30 border-t-teal-500 rounded-full animate-spin"></div>';
      slotsContainer.classList.remove('italic', 'text-slate-400');
    }

    try {
      const res = await fetch(`/api/slots?doctorId=${doctorId}&date=${date}`);
      const data = await res.json();

      if (data.slots && data.slots.length > 0) {
        slotsContainer!.innerHTML = data.slots.map((s: string) => `
          <button type="button" class="slot-btn py-2 px-1 text-xs font-bold border border-slate-200 rounded-lg hover:bg-teal-500 hover:text-white hover:border-teal-500 transition-all text-slate-600 bg-white shadow-sm" data-time="${s}">
            ${s}
          </button>
        `).join('');

        // Add event listeners to new buttons
        document.querySelectorAll('.slot-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            const time = (e.currentTarget as HTMLElement).dataset.time;
            timeInput.value = time || '';
            
            // Highlight selected
            document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('bg-teal-600', 'text-white', 'border-teal-600', 'scale-105'));
            (e.currentTarget as HTMLElement).classList.add('bg-teal-600', 'text-white', 'border-teal-600', 'scale-105');
            
            submitBtn.disabled = false;
          });
        });
      } else {
        slotsContainer!.innerHTML = `<p class="col-span-full py-4 text-rose-500 font-medium text-xs">${data.message || 'No hay horarios disponibles para este día.'}</p>`;
        submitBtn.disabled = true;
      }
    } catch (error) {
      slotsContainer!.innerHTML = '<p class="col-span-full py-4 text-rose-500 text-xs">Error al cargar horarios.</p>';
      submitBtn.disabled = true;
    }
  }

  doctorSelect?.addEventListener('change', updateSlots);
  dateInput.addEventListener('change', updateSlots);

  // Si el especialista está bloqueado, intentar cargar slots si hay fecha
  if (!doctorSelect && dateInput.value) {
    updateSlots();
  }

  // Form Submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    const formData = new FormData(form);
    const date = formData.get('date');
    const time = formData.get('time');
    const dateTime = `${date} ${time}:00`;

    const payload = {
      doctorId: formData.get('doctorId'),
      patientId: formData.get('patientId'),
      dateTime,
      reason: formData.get('reason')
    };

    try {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<div class="w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>';

      const res = await fetch('/api/appointments/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const data = await res.json();

      if (data.success) {
        if (formStatus) {
          formStatus.innerHTML = `
            <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm mb-6 flex items-center justify-between">
              <div class="flex items-center gap-2 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                Cita agendada exitosamente.
              </div>
              <a href="/appointments" class="text-emerald-800 underline font-bold">Volver</a>
            </div>
          `;
          formStatus.classList.remove('hidden');
          form.classList.add('opacity-50', 'pointer-events-none');
        }
        
        // Final redirect after delay
        setTimeout(() => {
          window.location.href = '/appointments';
        }, 1500);
      } else {
        alert('Error: ' + data.error);
        submitBtn.disabled = false;
        submitBtn.innerText = 'Confirmar Cita';
      }
    } catch (error) {
      alert('Error al conectar con el servidor.');
      submitBtn.disabled = false;
      submitBtn.innerText = 'Confirmar Cita';
    }
  });
</script>
