---
/**
 * FORMULARIO DE CITAS MÉDICAS
 * Este componente maneja tanto la creación como la edición de citas.
 * Implementa lógica especial para Estudiantes (auto-agendado).
 */
import { db } from '../../turso';
import { ROLES } from '../../functions/checkRole';

interface Props {
  appointment?: any; // Objeto de cita opcional (para edición)
}

const { appointment } = Astro.props;

// 1. CARGA DE CATÁLOGOS: Obtenemos pacientes y médicos disponibles desde Turso
const patientsRes = await db.execute(`SELECT patientId, firstName, lastName FROM Patients JOIN Users ON Patients.patientId = Users.userId`);
const patients = patientsRes.rows;

const url = Astro.url;
let lockedPatientId = url.searchParams.get('patientId');

// 2. LÓGICA DE SEGURIDAD (Estudiante):
// Si el usuario es un Estudiante, forzamos que el patientId sea el suyo.
const user = Astro.locals.user;
if (user?.roleId === ROLES.ESTUDIANTE) {
  lockedPatientId = String(user.userId);
}

// Obtenemos la lista de médicos especialistas
const doctorsRes = await db.execute(`SELECT userId, firstName, lastName, roleName FROM Users JOIN Roles ON Users.roleId = Roles.roleId WHERE Roles.roleName IN ('Doctor', 'Jefe Médico', 'Nutriólogo')`);
const doctors = doctorsRes.rows;

let success = false;

// 3. PROCESAMIENTO DEL FORMULARIO (POST)
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const patientId = data.get('patientId');
  const doctorId = data.get('doctorId');
  const dateStr = data.get('date');
  const timeStr = data.get('time');
  
  // Combinamos fecha y hora para el formato de BD
  const dateTime = `${dateStr} ${timeStr}:00`;

  // Inserción en la tabla de Appointments
  await db.execute({
    sql: `INSERT INTO Appointments (patientId, doctorId, dateTime, status) VALUES (?, ?, ?, 'Pendiente')`,
    args: [patientId as string, doctorId as string, dateTime]
  });

  success = true;
}
---

{/* Mensaje de éxito dinámico */}
{success && (
  <div class="bg-emerald-50 border border-emerald-200 text-emerald-700 px-4 py-3 rounded-xl text-sm mb-6 flex items-center justify-between">
    <div class="flex items-center gap-2 font-medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      Cita agendada exitosamente.
    </div>
    <a href={user?.roleId === ROLES.ESTUDIANTE ? `/patients/${user.userId}` : "/appointments"} class="text-emerald-800 underline font-bold">
      {user?.roleId === ROLES.ESTUDIANTE ? 'Volver a mi Expediente' : 'Ver Agenda'}
    </a>
  </div>
)}

<form method="POST" class="space-y-6">
  <div class="glass-card rounded-2xl p-6">
    <h3 class="text-lg font-bold text-slate-800 mb-4 border-b border-white/60 pb-2">Datos de la Cita</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div class="md:col-span-2">
        <label for="patientId" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Paciente</label>
        
        {/* Si el paciente está bloqueado (Estudiante o viene de un expediente), no dejamos cambiarlo */}
        {lockedPatientId ? (
          <>
            <div class="w-full bg-slate-100 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 font-semibold shadow-sm cursor-not-allowed">
              {patients.find((p: any) => String(p.patientId) === lockedPatientId)?.firstName} {patients.find((p: any) => String(p.patientId) === lockedPatientId)?.lastName} (Exp. #{String(lockedPatientId).padStart(4, '0')})
            </div>
            <input type="hidden" name="patientId" value={lockedPatientId} />
          </>
        ) : (
          <select name="patientId" id="patientId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
            <option value="">Seleccionar Paciente</option>
            {patients.map((p: any) => (
              <option value={String(p.patientId)} selected={String(p.patientId) === String(lockedPatientId)}>{p.firstName} {p.lastName} (Exp. #{String(p.patientId).padStart(4, '0')})</option>
            ))}
          </select>
        )}
      </div>

      <div>
        <label for="doctorId" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Médico/Especialista</label>
        <select name="doctorId" id="doctorId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="">Asignar Médico</option>
          {doctors.map((d: any) => (
            <option value={String(d.userId)}>{d.firstName} {d.lastName} ({d.roleName})</option>
          ))}
        </select>
      </div>

      <div>
        <label for="date" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Fecha</label>
        <input type="date" name="date" id="date" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
      </div>

      <div>
        <label for="time" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Hora</label>
        <input type="time" name="time" id="time" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
      </div>
    </div>
  </div>

  <div class="flex justify-end gap-4">
    {/* El botón cancelar redirige inteligentemente según el rol */}
    <a href={user?.roleId === ROLES.ESTUDIANTE ? `/patients/${user.userId}` : "/appointments"} class="px-5 py-2.5 bg-white/50 border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-colors">Cancelar</a>
    <button type="submit" class="px-6 py-2.5 bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all active:scale-[0.98]">
      {appointment ? 'Actualizar Cita' : 'Agendar Cita'}
    </button>
  </div>
</form>
