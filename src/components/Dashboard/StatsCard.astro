---
interface Props {
  title: string;
  value: string | number;
  icon: string; // SVG path
  trendLabel?: string;
  href?: string;
}

const { title, value, icon, trendLabel, colorClass = "from-teal-500 to-emerald-500", href } = Astro.props;

const Tag = href ? 'a' : 'div';
---

<Tag href={href} class="block glass-card rounded-2xl p-6 hover:shadow-lg transition-all duration-300 hover:scale-[1.02]">
  <div class="flex items-center justify-between">
    <div class={`w-12 h-12 bg-gradient-to-br ${colorClass} rounded-xl flex items-center justify-center shadow-md`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6 text-white" set:html={icon} />
    </div>
    {trendLabel && (
      <div class="flex items-center text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-full text-xs font-semibold">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5 mr-1"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"/><polyline points="16 7 22 7 22 13"/></svg>
        <span>{trendLabel}</span>
      </div>
    )}
  </div>
  <div class="mt-4">
    <h3 class="text-3xl font-bold text-slate-800 tracking-tight">{value}</h3>
    <p class="text-sm font-medium text-slate-500 mt-1">{title}</p>
  </div>
</Tag>
