---
interface Props {
  alerts: Array<{
    type: 'stock' | 'injury' | 'note';
    message: string;
    link?: string;
  }>;
}

const { alerts } = Astro.props;

const ICONS = {
  stock: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  injury: '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  note: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>'
};

const COLORS = {
  stock: 'bg-amber-50 border-amber-200 text-amber-800',
  injury: 'bg-rose-50 border-rose-200 text-rose-800',
  note: 'bg-sky-50 border-sky-200 text-sky-800'
};
---

{alerts.length > 0 && (
  <div class="mb-8 space-y-3">
    {alerts.map(alert => (
      <div class={`flex items-start gap-3 p-4 rounded-xl border ${COLORS[alert.type]} shadow-sm`}>
        <div class="mt-0.5 shrink-0 animate-pulse">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS[alert.type]} />
        </div>
        <div class="flex-1">
          <p class="text-sm font-medium">{alert.message}</p>
        </div>
        {alert.link && (
          <a href={alert.link} class="text-xs font-semibold underline underline-offset-2 opacity-80 hover:opacity-100 transition-opacity">
            Ver detalle
          </a>
        )}
      </div>
    ))}
  </div>
)}
