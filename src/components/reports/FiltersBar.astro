---
interface Props {
  isAdmin: boolean;
  doctors: any[];
}
const { isAdmin, doctors } = Astro.props;
---

<div class="flex flex-col sm:flex-row gap-3 items-center bg-white p-2 rounded-xl shadow-sm border border-slate-200">
    <div class="flex items-center gap-2 px-2 border-r border-slate-100">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
        <select id="filterRange" class="bg-transparent text-sm font-semibold text-slate-700 focus:outline-none cursor-pointer">
            <option value="week">Últimos 7 días</option>
            <option value="month" selected>Últimos 30 días</option>
            <option value="year">Último Año</option>
        </select>
    </div>

    {isAdmin && (
    <div class="flex items-center gap-2 px-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <select id="filterDoctor" class="bg-transparent text-sm font-semibold text-slate-700 focus:outline-none cursor-pointer w-40 truncate">
            <option value="">Todos los Especialistas</option>
            {doctors.map(d => (
                <option value={d.userId}>{d.firstName} {d.lastName} ({d.roleName})</option>
            ))}
        </select>
    </div>
    )}
</div>
