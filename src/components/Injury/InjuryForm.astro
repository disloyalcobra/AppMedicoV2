---
// Form for registering an injury
// If isAthlete is true, shows coach and sport fields
// If requiresInsurance is true, shows insurance fields
---

<form method="POST" id="injuryForm" class="space-y-6">
  <div class="glass-card rounded-2xl p-6">
    <h3 class="text-lg font-bold text-slate-800 mb-4 border-b border-white/60 pb-2">Información del Paciente</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label for="patientId" class="block text-sm font-semibold text-slate-700 mb-1.5">Paciente</label>
        <select name="patientId" id="patientId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="">Seleccionar Paciente afectado</option>
          <option value="1" data-athlete="true">Juan Pérez (Atleta - Futbol)</option>
          <option value="2" data-athlete="false">María Lozano (Regular)</option>
          <option value="3" data-athlete="true">Carlos Ruiz (Atleta - Basquetbol)</option>
        </select>
      </div>

      <!-- Visible solo si el paciente es atleta -->
      <div id="coachFieldContainer" class="hidden transition-opacity duration-300">
        <label for="coachId" class="block text-sm font-semibold text-amber-800 mb-1.5">Entrenador Responsable</label>
        <select name="coachId" id="coachId" class="w-full bg-amber-50/50 border border-amber-200/60 rounded-xl px-4 py-2.5 text-amber-900 focus:outline-none focus:ring-2 focus:ring-amber-500">
          <option value="">No aplica / Sin entrenador asignado</option>
          <option value="7">Entrenador Roberto (Futbol)</option>
          <option value="8">Entrenador Luis (Basquetbol)</option>
        </select>
        
        <label for="sport" class="block text-sm font-semibold text-amber-800 mt-4 mb-1.5">Deporte a reportar</label>
        <select name="sport" id="sport" class="w-full bg-amber-50/50 border border-amber-200/60 rounded-xl px-4 py-2.5 text-amber-900 focus:outline-none focus:ring-2 focus:ring-amber-500">
          <option value="">Selecciona Deporte</option>
          <option value="Futbol">Futbol</option>
          <option value="Basquetbol">Basquetbol</option>
          <option value="Natación">Natación</option>
          <option value="Atletismo">Atletismo</option>
        </select>
      </div>
    </div>
  </div>

  <div class="glass-card rounded-2xl p-6">
    <h3 class="text-lg font-bold text-slate-800 mb-4 border-b border-white/60 pb-2">Detalles de la Lesión</h3>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-5">
      <div>
        <label for="injuryDate" class="block text-sm font-semibold text-slate-700 mb-1.5">Fecha de la Lesión</label>
        <input type="date" name="injuryDate" id="injuryDate" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
      </div>

      <div>
        <label for="campusLocation" class="block text-sm font-semibold text-slate-700 mb-1.5">Ubicación (Campus)</label>
        <select name="campusLocation" id="campusLocation" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="Cancha de Futbol">Cancha de Futbol</option>
          <option value="Gimnasio">Gimnasio</option>
          <option value="Alberca">Alberca</option>
          <option value="Pista de Atletismo">Pista de Atletismo</option>
          <option value="Laboratorio">Laboratorio</option>
          <option value="Aula">Aula</option>
          <option value="Área común">Área común</option>
          <option value="Fuera del campus">Fuera del campus</option>
          <option value="Otro">Otro lugar</option>
        </select>
      </div>

      <div>
        <label for="severity" class="block text-sm font-semibold text-slate-700 mb-1.5">Gravedad Inicial</label>
        <select name="severity" id="severity" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="Leve">Leve (Requiere reposo menor)</option>
          <option value="Moderada">Moderada (Atención médica)</option>
          <option value="Grave">Grave (Emergencia/Traslado)</option>
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-5">
      <div>
        <label for="bodyZone" class="block text-sm font-semibold text-slate-700 mb-1.5">Zona del Cuerpo</label>
        <select name="bodyZone" id="bodyZone" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="Rodilla">Rodilla</option>
          <option value="Tobillo">Tobillo</option>
          <option value="Hombro">Hombro</option>
          <option value="Muñeca">Muñeca</option>
          <option value="Columna">Columna / Espalda</option>
          <option value="Cabeza">Cabeza / Cuello</option>
          <option value="Otro">Otra zona</option>
        </select>
      </div>

      <div>
        <label for="injuryType" class="block text-sm font-semibold text-slate-700 mb-1.5">Tipo de Lesión</label>
        <select name="injuryType" id="injuryType" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="Esguince">Esguince</option>
          <option value="Fractura">Fractura</option>
          <option value="Desgarro">Desgarro muscular</option>
          <option value="Contusión">Contusión / Golpe directo</option>
          <option value="Luxación">Luxación</option>
          <option value="Corte">Herida abierta / Corte</option>
          <option value="Otro">Otro</option>
        </select>
      </div>
    </div>

    <div>
      <label for="observations" class="block text-sm font-semibold text-slate-700 mb-1.5">Mecanismo de Lesión y Observaciones</label>
      <textarea name="observations" id="observations" rows="3" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="¿Cómo ocurrió la lesión? Detalles de cómo fue atendido inicialmente..." required></textarea>
    </div>
  </div>

  <div class="glass-card rounded-2xl p-6">
    <div class="flex items-center justify-between mb-4 border-b border-white/60 pb-2">
      <h3 class="text-lg font-bold text-slate-800">Seguro y Tratamiento</h3>
      <label class="relative inline-flex items-center cursor-pointer">
        <span class="mr-3 text-sm font-semibold text-slate-700">¿Involucra Seguro Universitario?</span>
        <input type="checkbox" name="requiresInsurance" value="1" class="sr-only peer" id="insuranceToggle">
        <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-teal-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:right-[22px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-teal-500"></div>
      </label>
    </div>

    <div id="insuranceFieldContainer" class="hidden mb-5 transition-opacity duration-300">
      <label for="insuranceNotes" class="block text-sm font-semibold text-teal-800 mb-1.5">Anotaciones para el Seguro</label>
      <textarea name="insuranceNotes" id="insuranceNotes" rows="2" class="w-full bg-teal-50 border border-teal-200/60 rounded-xl px-4 py-3 text-teal-900 focus:outline-none focus:ring-2 focus:ring-teal-500 placeholder:text-teal-400" placeholder="Hospital de traslado, número de folio, contacto emergencias..."></textarea>
    </div>

    <div>
      <label for="treatment" class="block text-sm font-semibold text-slate-700 mb-1.5">Tratamiento Inicial Indicado</label>
      <textarea name="treatment" id="treatment" rows="2" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="Hielo, reposo, vendaje tipo X..."></textarea>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <a href="/injuries" class="px-5 py-2.5 bg-white/50 border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-colors">Cancelar</a>
    <button type="submit" class="px-6 py-2.5 bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-semibold rounded-xl shadow-md hover:shadow-lg transition-all active:scale-[0.98]">Guardar Registro de Lesión</button>
  </div>
</form>

<script>
  // Simple vanilla JS to toggle dynamic fields
  const patientSelect = document.getElementById('patientId') as HTMLSelectElement;
  const coachField = document.getElementById('coachFieldContainer');
  
  if (patientSelect && coachField) {
    patientSelect.addEventListener('change', (e) => {
      const selectedOption = patientSelect.options[patientSelect.selectedIndex];
      const isAthlete = selectedOption.getAttribute('data-athlete') === 'true';
      if (isAthlete) {
        coachField.classList.remove('hidden');
      } else {
        coachField.classList.add('hidden');
      }
    });
  }

  const insuranceToggle = document.getElementById('insuranceToggle') as HTMLInputElement;
  const insuranceField = document.getElementById('insuranceFieldContainer');

  if (insuranceToggle && insuranceField) {
    insuranceToggle.addEventListener('change', (e) => {
      if ((e.target as HTMLInputElement).checked) {
        insuranceField.classList.remove('hidden');
      } else {
        insuranceField.classList.add('hidden');
      }
    });
  }
</script>
