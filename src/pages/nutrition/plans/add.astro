---
import Layout from '../../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../../functions/checkRole';
import { db } from '../../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.NUTRIOLOGO, ROLES.DOCTOR, ROLES.JEFE_MEDICO])) {
  return Astro.redirect('/403');
}

const url = Astro.url;
const editPlanId = url.searchParams.get('edit');
const patientId = url.searchParams.get('patientId');

// Fetch existing plan if in edit mode
let existingPlan: any = null;
if (editPlanId) {
    const planRes = await db.execute({
        sql: `SELECT * FROM NutritionalPlans WHERE planId = ?`,
        args: [editPlanId]
    });
    if (planRes.rows.length > 0) {
        existingPlan = planRes.rows[0];
    }
}

// Patients who HAVE a profile but DO NOT have an active plan (or just all patients with profiles)
let patientsWithProfiles: any[] = [];
let targetPatient: any = null;

if (patientId) {
    const pRes = await db.execute({
        sql: `SELECT p.patientId, u.firstName, u.lastName, np.profileId, np.nutritionalObjective 
              FROM Patients p 
              JOIN Users u ON p.patientId = u.userId 
              JOIN NutritionalProfiles np ON p.patientId = np.patientId
              WHERE p.patientId = ?`, 
        args: [patientId]
    });
    if (pRes.rows.length > 0) {
        targetPatient = pRes.rows[0];
    }
} else if (!editPlanId) {
    const pRes = await db.execute(`
        SELECT p.patientId, u.firstName, u.lastName 
        FROM Patients p 
        JOIN Users u ON p.patientId = u.userId 
        JOIN NutritionalProfiles np ON p.patientId = np.patientId
    `);
    patientsWithProfiles = pRes.rows;
    if(patientsWithProfiles.length === 0) {
        return Astro.redirect('/nutrition/profiles'); // Need a profile first
    }
}

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const formEditPlanId = data.get('editPlanId') as string;
  const finalPatientId = patientId || data.get('patientId') as string;
  const nutritionistId = user?.userId || 1; // Fallback to 1 if undefined for auth

  const macrosDistribution = `Carbohidratos: ${data.get('carbohydratesPercent')}%, Proteínas: ${data.get('proteinsPercent')}%, Grasas: ${data.get('fatsPercent')}%`;

  // Build the weekly menu from structured fields
  const weeklyMenu = `DESAYUNO:
${data.get('desayuno') || 'No especificado'}

COLACIÓN MATUTINA:
${data.get('colacion_matutina') || 'No especificado'}

COMIDA:
${data.get('comida') || 'No especificado'}

COLACIÓN VESPERTINA:
${data.get('colacion_vespertina') || 'No especificado'}

CENA:
${data.get('cena') || 'No especificado'}`;

  if (formEditPlanId) {
    await db.execute({
      sql: `UPDATE NutritionalPlans SET
              caloricRequirement = ?, macrosDistribution = ?, weeklyMenu = ?, generalRecommendations = ?
            WHERE planId = ?`,
      args: [
        data.get('caloricRequirement') as string,
        macrosDistribution,
        weeklyMenu,
        data.get('generalRecommendations') as string,
        formEditPlanId
      ]
    });
    return Astro.redirect(`/nutrition/plans/${formEditPlanId}`);
  } else {
    const insertedPlan = await db.execute({
      sql: `INSERT INTO NutritionalPlans (
              patientId, nutritionistId, caloricRequirement, macrosDistribution,
              weeklyMenu, equivalencesList, generalRecommendations, patientAccepted
            ) VALUES (?, ?, ?, ?, ?, ?, ?, 0)`,
      args: [
        finalPatientId,
        nutritionistId,
        data.get('caloricRequirement') as string,
        macrosDistribution,
        weeklyMenu,
        'N/A', // Equivalences JSON no longer used as primary
        data.get('generalRecommendations') as string
      ]
    });

    // Auto-vinculación Nutriólogo -> Paciente
    await db.execute({
      sql: `INSERT OR IGNORE INTO User_Patient (userId, patientId, roleType) VALUES (?, ?, 'Nutritionist')`,
      args: [nutritionistId, finalPatientId]
    });

    return Astro.redirect('/nutrition/plans/' + String(insertedPlan.lastInsertRowid));
  }
}

// Utility to extract sections for prefilling
let parsedMeals = {
    desayuno: '',
    colacion_matutina: '',
    comida: '',
    colacion_vespertina: '',
    cena: ''
};

let prefillMacros = {
    carbs: '',
    prot: '',
    fats: ''
};

if (existingPlan) {
    // Parse macros string "Carbohidratos: 50%, Proteínas: 30%, Grasas: 20%"
    const macrosMatch = existingPlan.macrosDistribution?.match(/Carbohidratos: (\d+)%, Proteínas: (\d+)%, Grasas: (\d+)%/);
    if (macrosMatch) {
        prefillMacros.carbs = macrosMatch[1];
        prefillMacros.prot = macrosMatch[2];
        prefillMacros.fats = macrosMatch[3];
    }

    if (existingPlan.weeklyMenu) {
        const sections = String(existingPlan.weeklyMenu).split('\n\n');
        for (const section of sections) {
            const lines = section.split('\n');
            const title = lines[0].replace(':', '').trim();
            const content = lines.slice(1).join('\n').trim();
            
            if (title === 'DESAYUNO') parsedMeals.desayuno = content;
            if (title === 'COLACIÓN MATUTINA') parsedMeals.colacion_matutina = content;
            if (title === 'COMIDA') parsedMeals.comida = content;
            if (title === 'COLACIÓN VESPERTINA') parsedMeals.colacion_vespertina = content;
            if (title === 'CENA') parsedMeals.cena = content;
        }
    }
}
---

<Layout title={existingPlan ? "Editar Plan Nutricional" : "Diseñar Plan Nutricional"}>
  <div class="mb-8">
    <div class="flex items-center gap-3 text-sm font-semibold text-slate-500 mb-2">
      <a href="/nutrition/profiles" class="hover:text-teal-600 transition-colors">Volver a Perfiles</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-teal-700">{existingPlan ? "Edición de Plan" : "Diseño de Plan"}</span>
    </div>
    <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">{existingPlan ? "Editar Plan Nutricional" : "Nuevo Plan Nutricional"}</h1>
    </div>
  </div>

  <form method="POST" class="max-w-4xl space-y-6">
    {existingPlan && <input type="hidden" name="editPlanId" value={existingPlan.planId} />}
    <div class="glass-card rounded-2xl p-6 mb-6">
        <h3 class="text-lg font-bold text-slate-800 border-b border-white/60 pb-2 mb-6">Paciente Objetivo</h3>
        {targetPatient ? (
            <div class="w-full bg-slate-100 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 font-semibold shadow-sm text-sm flex items-center justify-between">
                <div>
                   {targetPatient.firstName} {targetPatient.lastName}
                </div>
                <div class="text-slate-500 text-xs font-normal">
                   Meta: <span class="font-bold text-teal-700">{targetPatient.nutritionalObjective}</span>
                </div>
            </div>
        ) : (
            <select name="patientId" required class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 shadow-sm">
                <option value="">Seleccione un paciente con evaluación previa...</option>
                {patientsWithProfiles.map(p => (
                    <option value={p.patientId}>{p.firstName} {p.lastName}</option>
                ))}
            </select>
        )}
    </div>

    <div class="glass-card rounded-2xl p-6">
      <h3 class="text-lg font-bold text-slate-800 border-b border-white/60 pb-2 mb-6">Cálculo Calórico y Macronutrientes</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Calorías Diarias (kcal)</label>
            <input type="number" name="caloricRequirement" value={existingPlan?.caloricRequirement || ''} required class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 font-bold focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Ej. 2500" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">% Carbohidratos</label>
            <input type="number" name="carbohydratesPercent" value={prefillMacros.carbs} required class="w-full bg-amber-50/50 border border-amber-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500" placeholder="Ej. 50" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">% Proteínas</label>
            <input type="number" name="proteinsPercent" value={prefillMacros.prot} required class="w-full bg-rose-50/50 border border-rose-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-rose-500" placeholder="Ej. 30" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">% Grasas</label>
            <input type="number" name="fatsPercent" value={prefillMacros.fats} required class="w-full bg-sky-50/50 border border-sky-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-sky-500" placeholder="Ej. 20" />
          </div>
      </div>
      <p class="text-[10px] text-slate-400 font-bold tracking-widest uppercase mt-3 text-right">La suma de los % debe ser 100</p>
    </div>

    <div class="glass-card rounded-2xl p-6 bg-gradient-to-br from-amber-50/30 to-orange-50/30 border border-amber-100">
        <h3 class="text-lg font-bold text-slate-800 border-b border-amber-100 pb-2 mb-6">Plan Alimenticio Diario</h3>

        <div class="space-y-6">
            <!-- Desayuno -->
            <div class="bg-white/50 rounded-xl p-4 border border-amber-100/60">
                <h4 class="text-sm font-bold text-amber-800 mb-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M7 3h10v9a5 5 0 0 1-10 0V3Z"/></svg>
                    Desayuno
                </h4>
                <textarea name="desayuno" rows="3" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm" placeholder="Ej: 2 huevos revueltos, 2 rebanadas de pan integral, 1 taza de leche descremada...">{parsedMeals.desayuno}</textarea>
            </div>

            <!-- Colación Matutina -->
            <div class="bg-white/50 rounded-xl p-4 border border-amber-100/60">
                <h4 class="text-sm font-bold text-amber-800 mb-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2Z"/></svg>
                    Colación Matutina
                </h4>
                <textarea name="colacion_matutina" rows="2" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm" placeholder="Ej: 1 manzana mediana, 10 almendras...">{parsedMeals.colacion_matutina}</textarea>
            </div>

            <!-- Comida -->
            <div class="bg-white/50 rounded-xl p-4 border border-amber-100/60">
                <h4 class="text-sm font-bold text-amber-800 mb-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M7 12h10"/><path d="M10 18h4"/></svg>
                    Comida
                </h4>
                <textarea name="comida" rows="4" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm" placeholder="Ej: 150g de pechuga de pollo a la plancha, 1 taza de arroz integral, 2 tazas de ensalada verde con limón...">{parsedMeals.comida}</textarea>
            </div>

            <!-- Colación Vespertina -->
            <div class="bg-white/50 rounded-xl p-4 border border-amber-100/60">
                <h4 class="text-sm font-bold text-amber-800 mb-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                    Colación Vespertina
                </h4>
                <textarea name="colacion_vespertina" rows="2" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm" placeholder="Ej: 1 yogurt natural sin azúcar, 1/2 taza de fresas...">{parsedMeals.colacion_vespertina}</textarea>
            </div>

            <!-- Cena -->
            <div class="bg-white/50 rounded-xl p-4 border border-amber-100/60">
                <h4 class="text-sm font-bold text-amber-800 mb-3 flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v18"/><path d="M7 12h10"/></svg>
                    Cena
                </h4>
                <textarea name="cena" rows="3" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm" placeholder="Ej: 120g de pescado al horno, 1 taza de verduras al vapor...">{parsedMeals.cena}</textarea>
            </div>

            <div class="bg-white/70 rounded-xl p-4 border border-slate-200/60">
                <label class="block text-sm font-semibold text-slate-700 mb-2">Recomendaciones Generales</label>
                <textarea name="generalRecommendations" rows="3" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500 text-sm" placeholder="Ej: Evitar lácteos enteros, consumir 3L de agua diarios, evitar azúcares refinados...">{existingPlan?.generalRecommendations || ''}</textarea>
            </div>
        </div>
    </div>

    <div class="flex justify-end gap-3 pt-4">
      <a href={existingPlan ? `/nutrition/plans/${existingPlan.planId}` : "/nutrition/profiles"} class="px-5 py-2.5 bg-white/50 border border-slate-200 text-slate-700 font-semibold rounded-xl hover:bg-slate-50 transition-colors">Cancelar</a>
      <button type="submit" class="px-8 py-2.5 bg-gradient-to-r from-amber-500 to-orange-500 text-white font-bold text-lg rounded-xl shadow-md hover:shadow-lg transition-all active:scale-[0.98]">
        {existingPlan ? "Guardar Cambios del Plan" : "Generar y Enviar Plan al Paciente"}
      </button>
    </div>
  </form>
</Layout>
