---
import Layout from '../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.STAFF, ROLES.ADMINISTRADOR, ROLES.NUTRIOLOGO, ROLES.ESTUDIANTE])) {
  return Astro.redirect('/403');
}

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

const aptRes = await db.execute({
    sql: `SELECT a.*, p.patientId, p.gender, p.dateOfBirth, 
                 u.firstName as pFirst, u.lastName as pLast, 
                 ud.firstName as dFirst, ud.lastName as dLast
          FROM Appointments a
          JOIN Patients p ON a.patientId = p.patientId
          JOIN Users u ON p.patientId = u.userId
          JOIN Users ud ON a.specialistId = ud.userId
          WHERE a.appointmentId = ?`,
    args: [id]
});

if (aptRes.rows.length === 0) {
    return Astro.redirect('/404');
}

const app = aptRes.rows[0] as any;

// Check for existing session (if Fisioterapia)
let hasSession = false;
let activePlans: any[] = [];
if (app.appointmentType === 'Fisioterapia') {
    const sessionRes = await db.execute({
        sql: `SELECT sessionId FROM PhysiotherapySessions WHERE appointmentId = ?`,
        args: [id]
    });
    hasSession = sessionRes.rows.length > 0;

    const plansRes = await db.execute({
        sql: `SELECT planId, goals FROM PhysiotherapyPlans WHERE patientId = ? AND status = 'Activo'`,
        args: [app.patientId]
    });
    activePlans = plansRes.rows;
}

// Security: Students can only view their own appointments
if (user?.roleId === ROLES.ESTUDIANTE && Number(user.userId) !== Number(app.patientId)) {
    return Astro.redirect('/403');
}

// Parse Date and Time safely
const dateObj = new Date(String(app.dateTime || '').replace(' ', 'T'));
const dateStr = dateObj.toLocaleDateString('es-MX', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
const timeStr = dateObj.toLocaleTimeString('es-MX', { hour: '2-digit', minute:'2-digit', hour12: true });

// Handle Form Submit for changing status
if (Astro.request.method === 'POST') {
    const data = await Astro.request.formData();
    const action = data.get('action') as string;
    
    if (action === 'confirm') {
        await db.execute({
            sql: `UPDATE Appointments SET status = 'Confirmada', proposedDateTime = NULL WHERE appointmentId = ?`,
            args: [id]
        });
    } else if (action === 'accept_proposed') {
        await db.execute({
            sql: `UPDATE Appointments SET status = 'Confirmada', dateTime = proposedDateTime, proposedDateTime = NULL WHERE appointmentId = ?`,
            args: [id]
        });
    } else if (action === 'reject') {
        await db.execute({
            sql: `UPDATE Appointments SET status = 'Rechazada' WHERE appointmentId = ?`,
            args: [id]
        });
    } else if (action === 'reschedule') {
        const newDate = data.get('rescheduleDate');
        const newTime = data.get('rescheduleTime');
        const proposedDateTime = `${newDate} ${newTime}:00`;
        
        await db.execute({
            sql: `UPDATE Appointments SET status = 'Reagendada', proposedDateTime = ? WHERE appointmentId = ?`,
            args: [proposedDateTime, id]
        });
    } else if (action === 'complete') {
        await db.execute({
            sql: `UPDATE Appointments SET status = 'Completada' WHERE appointmentId = ?`,
            args: [id]
        });
    } else if (action === 'cancel') {
        await db.execute({
            sql: `UPDATE Appointments SET status = 'Cancelada' WHERE appointmentId = ?`,
            args: [id]
        });
    }
    
    return Astro.redirect(`/appointments/${id}`);
}

const statusStyles: any = {
  'En Progreso': 'bg-sky-100 text-sky-700 border-sky-200',
  'Pendiente': 'bg-amber-100 text-amber-700 border-amber-200',
  'Confirmada': 'bg-emerald-100 text-emerald-700 border-emerald-200',
  'Completada': 'bg-teal-100 text-teal-700 border-teal-200',
  'Cancelada': 'bg-rose-100 text-rose-700 border-rose-200',
  'Reagendada': 'bg-indigo-100 text-indigo-700 border-indigo-200',
  'Rechazada': 'bg-slate-100 text-slate-700 border-slate-200'
};
---
<Layout title={`Detalles de Cita #${app.appointmentId}`}>
  <div class="mb-8">
    <div class="flex items-center gap-3 text-sm font-semibold text-slate-500 mb-2">
      <a href="/appointments" class="hover:text-teal-600 transition-colors">Volver a la Agenda</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-teal-700">Detalles de Cita</span>
    </div>
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Cita #{String(app.appointmentId).padStart(4, '0')}</h1>
        <span class={`px-4 py-1.5 rounded-full text-sm font-bold uppercase tracking-widest border ${statusStyles[app.status as string]}`}>
            {app.status}
        </span>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
      <div class="lg:col-span-2 space-y-6">
          <div class="glass-card rounded-2xl p-6">
              <h3 class="font-bold text-slate-800 border-b border-slate-100 pb-3 mb-6 text-lg">Información del Evento</h3>
              
              <div class="grid grid-cols-2 gap-6 mb-8">
                  <div class="bg-slate-50 border border-slate-100 p-4 rounded-xl">
                      <span class="text-xs text-slate-400 font-bold uppercase tracking-widest block mb-1">Fecha Programada</span>
                      <p class="text-slate-800 font-semibold capitalize">{dateStr}</p>
                  </div>
                  <div class="bg-slate-50 border border-slate-100 p-4 rounded-xl">
                      <span class="text-xs text-slate-400 font-bold uppercase tracking-widest block mb-1">Hora de Consulta</span>
                      <p class="text-slate-800 font-semibold text-xl">{timeStr}</p>
                  </div>
              </div>

              <div class="space-y-5">
                  <div>
                      <span class="text-xs text-slate-400 font-bold uppercase tracking-widest block mb-1">Doctor Asignado</span>
                      <p class="text-slate-700 font-medium flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-500"><path d="M12 4.5a2.5 2.5 0 0 0-5 0 2.5 2.5 0 0 0 5 0Z"/><path d="M14 13v-2a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v2"/><path d="M4 19v-2a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v2"/></svg>
                        Dr. {app.dFirst} {app.dLast}
                      </p>
                  </div>
                  <div>
                      <span class="text-xs text-slate-400 font-bold uppercase tracking-widest block mb-2">Motivo de la Cita / Comentarios</span>
                      <div class="bg-white/60 p-4 rounded-xl border border-slate-100 text-slate-600 italic">
                          {'Sin motivo especificado.'}
                      </div>
                  </div>
              </div>
          </div>
          
          <div class="glass-card rounded-2xl p-6 bg-gradient-to-br from-teal-50/50 to-sky-50/50 border border-teal-100/50">
              <h3 class="font-bold text-slate-800 border-b border-teal-100 pb-3 mb-6 text-lg">Paciente</h3>
              <div class="flex items-center gap-4 mb-4">
                  <div class="w-14 h-14 bg-teal-100 text-teal-700 rounded-xl flex items-center justify-center font-bold text-xl shadow-sm border border-teal-200">
                      {String(app.pFirst)[0]}{String(app.pLast)[0]}
                  </div>
                  <div>
                      <h4 class="font-bold text-slate-800 text-xl">{app.pFirst} {app.pLast}</h4>
                      <p class="text-slate-500 text-sm">Expediente #{String(app.patientId).padStart(4, '0')}</p>
                  </div>
              </div>
              <a href={`/patients/${app.patientId}`} class="inline-flex items-center justify-center w-full px-4 py-2 border border-slate-200 text-slate-600 font-semibold rounded-xl hover:bg-white hover:text-teal-700 hover:border-teal-200 transition-colors shadow-sm gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                Ver Expediente Clínico Completo
              </a>
          </div>
      </div>

      <div class="lg:col-span-1 space-y-6">
          <div class="glass-card rounded-2xl p-6 border border-slate-200/60 sticky top-24">
              <h3 class="font-bold text-slate-800 border-b border-slate-100 pb-3 mb-6 text-sm uppercase tracking-widest">Acciones de Gestión</h3>
              
              <div class="space-y-3">
                  {/* ACTIONS FOR DOCTOR */}
                  {(user?.roleId === ROLES.DOCTOR || user?.roleId === ROLES.JEFE_MEDICO || user?.roleId === ROLES.ADMINISTRADOR) && (
                      <>
                          {app.status === 'Pendiente' && (
                              <form method="POST">
                                  <input type="hidden" name="action" value="confirm" />
                                  <button type="submit" class="w-full py-3 bg-emerald-500 text-white font-bold rounded-xl shadow-md hover:bg-emerald-600 transition-all flex items-center justify-center gap-2">
                                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                      Confirmar Cita
                                  </button>
                              </form>
                          )}
                          
                          {(app.status === 'Pendiente' || app.status === 'Confirmada') && (
                              <button id="openRescheduleBtn" class="w-full py-3 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-all flex items-center justify-center gap-2">
                                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/><path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"/><path d="M16 16h5v5"/></svg>
                                  Proponer Reagendado
                              </button>
                          )}

                          {app.status === 'Confirmada' && (
                              <form method="POST">
                                  <input type="hidden" name="action" value="complete" />
                                  <button type="submit" class="w-full py-3 bg-teal-600 text-white font-bold rounded-xl shadow-md hover:bg-teal-700 transition-all flex items-center justify-center gap-2">
                                      Marcar como Completada
                                  </button>
                              </form>
                          )}
                      </>
                  )}

                  {/* ACTIONS FOR PATIENT (Student) */}
                  {user?.roleId === ROLES.ESTUDIANTE && app.status === 'Reagendada' && (
                      <div class="p-4 bg-indigo-50 rounded-2xl border border-indigo-100 mb-4 animate-pulse-subtle">
                        <p class="text-xs text-indigo-700 font-bold mb-3 uppercase tracking-wider">El doctor ha propuesto un cambio:</p>
                        <p class="text-sm font-bold text-slate-800 mb-4">Nueva fecha: {new Date(app.proposedDateTime as string).toLocaleString('es-MX')}</p>
                        <div class="grid grid-cols-2 gap-2">
                            <form method="POST">
                                <input type="hidden" name="action" value="accept_proposed" />
                                <button type="submit" class="w-full py-2 bg-indigo-600 text-white text-xs font-bold rounded-lg shadow-sm">Aceptar</button>
                            </form>
                            <form method="POST">
                                <input type="hidden" name="action" value="reject" />
                                <button type="submit" class="w-full py-2 bg-white border border-rose-200 text-rose-600 text-xs font-bold rounded-lg shadow-sm">Rechazar</button>
                            </form>
                        </div>
                      </div>
                  )}

                  {(app.status === 'Pendiente' || app.status === 'Confirmada' || app.status === 'Reagendada') && (
                      <form method="POST" onsubmit="return confirm('¿Estás seguro de que deseas cancelar esta cita?')">
                          <input type="hidden" name="action" value="cancel" />
                          <button type="submit" class="w-full py-3 text-rose-600 text-sm font-bold hover:bg-rose-50 rounded-xl transition-colors">
                              Cancelar Cita
                          </button>
                      </form>
                  )}
              </div>

                  {app.status === 'Confirmada' && user?.roleId === ROLES.DOCTOR && (
                      <div class="pt-6 border-t border-slate-200 mt-4">
                          <a href={`/consultations/add?appointmentId=${app.appointmentId}`} class="w-full px-4 py-3 bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-bold rounded-xl transition-all shadow-md hover:shadow-lg flex justify-center items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                            Comenzar Consulta
                          </a>
                      </div>
                  )}

                  {app.status === 'Confirmada' && app.appointmentType === 'Fisioterapia' && !hasSession && (user?.roleId === ROLES.FISIOTERAPEUTA || user?.roleId === ROLES.ADMINISTRADOR) && (
                      <div class="pt-6 border-t border-slate-200 mt-4">
                          <button id="openSessionModalBtn" class="w-full px-4 py-3 bg-gradient-to-r from-violet-500 to-purple-600 text-white font-bold rounded-xl transition-all shadow-md hover:shadow-lg flex justify-center items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
                            Registrar Sesión Clínica
                          </button>
                      </div>
                  )}

                  {hasSession && (
                      <div class="pt-4 p-4 bg-emerald-50 border border-emerald-100 rounded-2xl flex items-center gap-2 text-emerald-700 font-bold text-xs mt-4">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        Sesión registrada correctamente
                      </div>
                  )}
          </div>
      </div>
  </div>

  {/* Reschedule Modal */}
  {/* Physiotherapy Session Modal */}
  {app.appointmentType === 'Fisioterapia' && !hasSession && (
    <div id="sessionModal" class="fixed inset-0 z-[80] hidden">
        <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
        <div class="absolute inset-0 flex items-center justify-center p-4">
            <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden animate-scale-in">
                <div class="p-6 border-b border-slate-100 flex items-center justify-between bg-violet-50">
                    <div>
                        <h2 class="text-xl font-bold text-violet-900">Registrar Sesión Clínica</h2>
                        <p class="text-xs text-violet-600 font-medium">Paciente: {app.pFirst} {app.pLast}</p>
                    </div>
                    <button type="button" id="closeSessionModal" class="text-slate-400 hover:text-slate-600 text-2xl font-light">&times;</button>
                </div>
                
                {activePlans.length > 0 ? (
                    <form id="sessionForm" class="p-6 space-y-4">
                        <input type="hidden" name="appointmentId" value={app.appointmentId} />
                        
                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Plan de Tratamiento Relacionado</label>
                            <select name="planId" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm">
                                {activePlans.map((p: any) => (
                                    <option value={p.planId}>Objetivo: {p.goals || 'Sin descripción'}</option>
                                ))}
                            </select>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Tipo de Terapia</label>
                                <select name="therapyType" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm">
                                    <option value="Electroterapia">Electroterapia</option>
                                    <option value="Ultrasonido">Ultrasonido</option>
                                    <option value="Termoterapia">Termoterapia</option>
                                    <option value="Ejercicio Terapéutico">Ejercicio Terapéutico</option>
                                    <option value="Masoterapia">Masoterapia</option>
                                    <option value="Kinesiotaping">Kinesiotaping</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Duración (min)</label>
                                <input type="number" name="durationMinutes" value="45" min="15" max="180" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm" />
                            </div>
                        </div>

                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Nivel de Dolor (0-10)</label>
                                <input type="range" name="painLevel" min="0" max="10" step="1" value="3" class="w-full h-2 bg-slate-100 rounded-lg appearance-none cursor-pointer accent-violet-600 mt-3" />
                                <div class="flex justify-between text-[10px] text-slate-400 font-bold mt-1">
                                    <span>Nulo</span>
                                    <span>Máximo</span>
                                </div>
                            </div>
                            <div>
                                <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Rango / Fuerza</label>
                                <input type="text" name="rangeOfMotion" placeholder="Ej: 90° flexión / 4/5" class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm" />
                            </div>
                        </div>

                        <div>
                            <label class="block text-[10px] font-bold text-slate-500 uppercase tracking-widest mb-1.5">Notas de Evolución</label>
                            <textarea name="progressNotes" rows="3" required placeholder="Describe los avances y respuesta al tratamiento..." class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm resize-none"></textarea>
                        </div>

                        <div class="pt-4 flex justify-end gap-3">
                            <button type="button" id="cancelSessionBtn" class="px-4 py-2 text-slate-500 font-bold">Cancelar</button>
                            <button type="submit" id="submitSessionBtn" class="px-8 py-2.5 bg-violet-600 text-white font-bold rounded-xl shadow-lg hover:bg-violet-700 transition-all">Registrar Sesión</button>
                        </div>
                    </form>
                ) : (
                    <div class="p-8 text-center space-y-4">
                        <div class="w-16 h-16 bg-amber-100 text-amber-600 rounded-full flex items-center justify-center mx-auto">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        </div>
                        <h3 class="font-bold text-slate-800">No hay plan activo</h3>
                        <p class="text-sm text-slate-500">Debes crear un Plan de Fisioterapia para este paciente antes de registrar sesiones.</p>
                        <a href={`/physiotherapy/plans/new?patientId=${app.patientId}&appointmentId=${app.appointmentId}`} class="inline-block px-6 py-2 bg-violet-600 text-white font-bold rounded-xl shadow-lg">Crear Plan Ahora</a>
                        <button type="button" id="closeNoPlanBtn" class="block w-full text-xs text-slate-400 hover:text-slate-600 font-bold mt-4">Cerrar</button>
                    </div>
                )}
            </div>
        </div>
    </div>
  )}

  <div id="rescheduleModal" class="fixed inset-0 z-[70] hidden">
    <div class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm"></div>
    <div class="absolute inset-0 flex items-center justify-center p-4">
      <form method="POST" class="bg-white rounded-3xl shadow-2xl w-full max-w-md overflow-hidden animate-scale-in">
        <input type="hidden" name="action" value="reschedule" />
        <div class="p-6 border-b border-slate-100 flex items-center justify-between">
            <h2 class="text-xl font-bold text-slate-800">Proponer Reagendado</h2>
            <button type="button" id="closeRescheduleBtn" class="text-slate-400 hover:text-slate-600 text-2xl font-light">&times;</button>
        </div>
        <div class="p-6 space-y-4">
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Nueva Fecha</label>
                <input type="date" name="rescheduleDate" id="resDate" required class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2" />
            </div>
            <div>
                <label class="block text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">Horarios Disponibles</label>
                <div id="resSlots" class="grid grid-cols-4 gap-2 p-3 bg-slate-50 rounded-xl min-h-[40px] text-[10px] text-center text-slate-400 italic">
                    Selecciona una fecha...
                </div>
                <input type="hidden" name="rescheduleTime" id="resTime" required />
            </div>
        </div>
        <div class="p-6 bg-slate-50 border-t border-slate-100 flex justify-end gap-3">
            <button type="button" id="cancelResBtn" class="px-4 py-2 text-slate-500 font-bold">Cancelar</button>
            <button type="submit" id="confirmResBtn" disabled class="px-6 py-2 bg-indigo-600 text-white font-bold rounded-xl shadow-lg disabled:opacity-50">Proponer</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ doctorId: app.specialistId }}>
    const modal = document.getElementById('rescheduleModal');
    const openBtn = document.getElementById('openRescheduleBtn');
    const closeBtn = document.getElementById('closeRescheduleBtn');
    const cancelBtn = document.getElementById('cancelResBtn');
    const resDate = document.getElementById('resDate');
    const resSlots = document.getElementById('resSlots');
    const resTime = document.getElementById('resTime');
    const confirmBtn = document.getElementById('confirmResBtn');

    openBtn?.addEventListener('click', () => modal?.classList.remove('hidden'));
    closeBtn?.addEventListener('click', () => modal?.classList.add('hidden'));
    cancelBtn?.addEventListener('click', () => modal?.classList.add('hidden'));

    resDate?.addEventListener('change', async (e) => {
        const date = e.target.value;
        if (!date) return;

        resSlots.innerHTML = '<div class="col-span-4 py-2 animate-pulse">Cargando...</div>';
        
        try {
            const res = await fetch(`/api/slots?doctorId=${doctorId}&date=${date}`);
            const data = await res.json();
            
            if (data.slots && data.slots.length > 0) {
                resSlots.innerHTML = data.slots.map(s => `
                    <button type="button" class="res-slot-btn py-1.5 border border-slate-200 rounded-lg bg-white hover:bg-indigo-500 hover:text-white transition-all text-xs font-bold" data-time="${s}">${s}</button>
                `).join('');

                document.querySelectorAll('.res-slot-btn').forEach(btn => {
                    btn.addEventListener('click', (ev) => {
                        resTime.value = ev.target.dataset.time;
                        document.querySelectorAll('.res-slot-btn').forEach(b => b.classList.remove('bg-indigo-600', 'text-white', 'border-indigo-600'));
                        ev.target.classList.add('bg-indigo-600', 'text-white', 'border-indigo-600');
                        confirmBtn.disabled = false;
                    });
                });
            } else {
                resSlots.innerHTML = '<p class="col-span-4 text-rose-500 text-[10px]">Sin disponibilidad.</p>';
                confirmBtn.disabled = true;
            }
        } catch (error) {
            resSlots.innerHTML = '<p class="col-span-4 text-rose-500 text-[10px]">Error.</p>';
        }
    });
  </script>

  <script>
    // Logic for Physiotherapy Session Modal
    const sessionModal = document.getElementById('sessionModal');
    const openSessionBtn = document.getElementById('openSessionModalBtn');
    const closeSessionBtn = document.getElementById('closeSessionModal');
    const cancelSessionBtn = document.getElementById('cancelSessionBtn');
    const closeNoPlanBtn = document.getElementById('closeNoPlanBtn');
    const sessionForm = document.getElementById('sessionForm') as HTMLFormElement;
    const submitSessionBtn = document.getElementById('submitSessionBtn') as HTMLButtonElement;

    openSessionBtn?.addEventListener('click', () => sessionModal?.classList.remove('hidden'));
    [closeSessionBtn, cancelSessionBtn, closeNoPlanBtn].forEach(btn => {
        btn?.addEventListener('click', () => sessionModal?.classList.add('hidden'));
    });

    sessionForm?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(sessionForm);
        const data = Object.fromEntries(formData.entries());

        try {
            submitSessionBtn.disabled = true;
            submitSessionBtn.innerHTML = '<div class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin"></div>';

            const res = await fetch('/api/physiotherapy/create-session-from-appointment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await res.json();
            if (result.success) {
                window.location.reload();
            } else {
                alert('Error: ' + result.error);
                submitSessionBtn.disabled = false;
                submitSessionBtn.innerText = 'Registrar Sesión';
            }
        } catch (error) {
            alert('Error de conexión');
            submitSessionBtn.disabled = false;
            submitSessionBtn.innerText = 'Registrar Sesión';
        }
    });
  </script>
</Layout>
