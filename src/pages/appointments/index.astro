---
import Layout from '../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.STAFF, ROLES.ADMINISTRADOR, ROLES.NUTRIOLOGO])) {
  return Astro.redirect('/403');
}

const url = Astro.url;
const monthParam = url.searchParams.get('month');
const yearParam = url.searchParams.get('year');

const today = new Date();
// SSR current timezone offset handling - simpler to just use parameter values or today's local values
const currentMonth = monthParam ? parseInt(monthParam) : today.getMonth(); // 0 is January
const currentYear = yearParam ? parseInt(yearParam) : today.getFullYear();

// Determine date boundaries for the SQL Query
const firstDayOfMonth = new Date(currentYear, currentMonth, 1);
const lastDayOfMonth = new Date(currentYear, currentMonth + 1, 0);

// Helper to format proper YYYY-MM-DD in local time
const formatDate = (date: Date) => {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
}

const startDateStr = formatDate(firstDayOfMonth);
const endDateStr = formatDate(lastDayOfMonth);

let query = `
  SELECT a.appointmentId as id, a.dateTime as fullDate, a.status, 
         p.patientId, u.firstName || ' ' || u.lastName as patient,
         ud.lastName as doctor
  FROM Appointments a
  JOIN Patients p ON a.patientId = p.patientId
  JOIN Users u ON p.patientId = u.userId
  JOIN Users ud ON a.doctorId = ud.userId
  WHERE date(a.dateTime) >= ? AND date(a.dateTime) <= ?
`;
let args: any[] = [startDateStr, endDateStr];

if (user.roleId === ROLES.DOCTOR) {
    query += ` AND a.doctorId = ?`;
    args.push(user.userId);
}

query += ` ORDER BY a.dateTime ASC`;

const aptRes = await db.execute({ sql: query, args });

const appointments = aptRes.rows.map((r: any) => {
    // Parse timestamp (SQLite format: YYYY-MM-DD HH:MM:SS)
    const dateTimeStr = (r.fullDate as string).replace(' ', 'T'); 
    const d = new Date(dateTimeStr);
    return {
        ...r,
        dateObj: d,
        day: d.getDate(),
        time: d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: true }),
        doctor: `Dr. ${r.doctor}`
    };
});

// Construct the Matrix for the Calendar Grid (Sunday - Saturday)
const startDayOfWeek = firstDayOfMonth.getDay(); // 0 is Sunday
const daysInMonth = lastDayOfMonth.getDate();

const calendarDays = [];

// Empty slots before the 1st
for (let i = 0; i < startDayOfWeek; i++) {
    calendarDays.push({ empty: true });
}

// Actual days
for (let i = 1; i <= daysInMonth; i++) {
    const dayApps = appointments.filter(a => a.day === i);
    const isToday = currentMonth === today.getMonth() && currentYear === today.getFullYear() && i === today.getDate();
    calendarDays.push({ 
        empty: false, 
        dayNumber: i, 
        apps: dayApps, 
        isToday 
    });
}

// Pagination Logic
let nextM = currentMonth + 1;
let nextY = currentYear;
if (nextM > 11) { nextM = 0; nextY++; }

let prevM = currentMonth - 1;
let prevY = currentYear;
if (prevM < 0) { prevM = 11; prevY--; }

const monthNames = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
---

<Layout title="Agenda Médica - Calendario">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Agenda de Citas</h1>
      <p class="text-slate-500 mt-1">Calendario clínico interactivo</p>
    </div>
    
    <a href="/appointments/add" class="bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-bold py-2.5 px-5 rounded-xl shadow-md hover:shadow-lg transition-all flex items-center gap-2 active:scale-95">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Agendar Cita
    </a>
  </div>

  <div class="glass-card rounded-2xl p-4 md:p-6 border border-slate-200/50 shadow-sm relative z-0">
    <!-- Header Calendario Nav -->
    <div class="flex flex-col sm:flex-row items-center justify-between mb-4 sm:mb-6 pb-4 border-b border-slate-200/60 gap-4">
      <div class="flex items-center gap-2">
        <a href={`?month=${prevM}&year=${prevY}`} class="w-10 h-10 flex items-center justify-center bg-white rounded-xl hover:bg-slate-50 text-slate-600 shadow-sm border border-slate-200 transition-colors" title="Mes Anterior">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
        </a>
        <h2 class="text-2xl font-black text-slate-800 w-56 text-center tracking-tight capitalize">
            {monthNames[currentMonth]} <span class="font-light text-slate-500">{currentYear}</span>
        </h2>
        <a href={`?month=${nextM}&year=${nextY}`} class="w-10 h-10 flex items-center justify-center bg-white rounded-xl hover:bg-slate-50 text-slate-600 shadow-sm border border-slate-200 transition-colors" title="Mes Siguiente">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
      </div>

      <div class="flex gap-2">
        <a href={`?month=${today.getMonth()}&year=${today.getFullYear()}`} class={`px-4 py-2 font-bold rounded-lg text-sm shadow-sm transition-colors border ${currentMonth === today.getMonth() && currentYear === today.getFullYear() ? 'bg-sky-100 text-sky-800 border-sky-200' : 'bg-white text-slate-600 border-slate-200 hover:bg-slate-50'}`}>
          Mes Actual
        </a>
      </div>
    </div>

    <!-- Grid de Calendario -->
    <div class="grid grid-cols-7 gap-px bg-slate-200 rounded-xl overflow-hidden border-2 border-slate-100 shadow-sm">
      <!-- Nombres de Dias -->
      {['Dom', 'Lun', 'Mar', 'Mié', 'Jue', 'Vie', 'Sáb'].map(day => (
        <div class="bg-slate-100/80 py-3 text-center text-xs font-bold text-slate-500 uppercase tracking-wider">{day}</div>
      ))}
      
      <!-- Celdas -->
      {calendarDays.map((dayObj: any) => (
        <div class={`min-h-[140px] p-1 md:p-2 border-t border-slate-100 transition-colors ${dayObj.empty ? 'bg-slate-50/50' : 'bg-white'} ${dayObj.isToday ? 'bg-sky-50/30' : ''}`}>
          {!dayObj.empty && (
            <div class="flex flex-col h-full relative group">
              <!-- Numero Dia -->
              <span class={`text-sm font-bold mb-1 w-7 h-7 flex items-center justify-center rounded-full z-10 ${dayObj.isToday ? 'bg-sky-600 text-white shadow-sm ring-4 ring-sky-100' : 'text-slate-500'}`}>
                {dayObj.dayNumber}
              </span>
              
              <!-- Contenedor Consultas -->
              <div class="space-y-1.5 flex-1 relative z-20">
                {dayObj.apps.map((app: any) => (
                  <a href={`/appointments/${app.id}`} 
                     title={`${app.time} - ${app.patient} (${app.status})`}
                     class={`block p-1.5 md:p-2 rounded-lg shadow-sm border-l-4 text-xs hover:scale-[1.03] transition-all relative overflow-hidden backdrop-blur-sm ${
                    app.status === 'En Progreso' ? 'bg-sky-50/80 border-sky-500 text-sky-900 shadow-sky-100' :
                    app.status === 'Completada' ? 'bg-emerald-50/80 border-emerald-500 text-emerald-900 shadow-emerald-100' :
                    app.status === 'Cancelada' ? 'bg-rose-50/80 border-rose-500 text-rose-900 shadow-rose-100' :
                    'bg-amber-50/80 border-amber-500 text-amber-900 shadow-amber-100'
                  }`}>
                    <!-- Overlay degrade para estados -->
                    <div class="absolute inset-0 opacity-10 bg-gradient-to-r from-transparent to-white pointer-events-none"></div>
                    
                    <div class="font-bold truncate leading-tight">{app.patient}</div>
                    <div class="flex justify-between items-center mt-1">
                      <span class="font-bold opacity-80 text-[9px] uppercase tracking-wider">{app.time}</span>
                      {user?.roleId !== ROLES.DOCTOR && <span class="opacity-60 truncate max-w-[40px] md:max-w-[60px] text-[10px] hidden sm:block">{app.doctor}</span>}
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )}
        </div>
      ))}
    </div>

    <!-- Leyenda de Estados Abajo -->
    <div class="flex flex-wrap items-center justify-center gap-4 mt-6">
        <div class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-widest"><div class="w-3 h-3 rounded-full bg-amber-500"></div> Pendiente</div>
        <div class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-widest"><div class="w-3 h-3 rounded-full bg-sky-500"></div> En Progreso</div>
        <div class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-widest"><div class="w-3 h-3 rounded-full bg-emerald-500"></div> Completada</div>
        <div class="flex items-center gap-2 text-xs font-semibold text-slate-500 uppercase tracking-widest"><div class="w-3 h-3 rounded-full bg-rose-500"></div> Cancelada</div>
    </div>
  </div>
</Layout>
