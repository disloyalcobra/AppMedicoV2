---
import Layout from '../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.FISIOTERAPEUTA, ROLES.ADMINISTRADOR, ROLES.JEFE_MEDICO])) {
  return Astro.redirect('/403');
}

const isAdmin = [ROLES.ADMINISTRADOR, ROLES.JEFE_MEDICO].includes(Number(user?.roleId));

// Cargar pacientes vinculados al fisioterapeuta (o todos si admin)
let patientsQuery = `
  SELECT DISTINCT p.patientId, u.firstName || ' ' || u.lastName as fullName
  FROM Patients p JOIN Users u ON p.patientId = u.userId
`;
let patientsArgs: any[] = [];
if (!isAdmin) {
  patientsQuery += ` JOIN User_Patient up ON p.patientId = up.patientId WHERE up.userId = ? AND up.roleType = 'Physiotherapist'`;
  patientsArgs.push(user?.userId);
}
patientsQuery += ` ORDER BY u.firstName`;
const patientsRes = await db.execute({ sql: patientsQuery, args: patientsArgs });

// Cargar fisioterapeutas (solo para admin al asignar)
let physios: any[] = [];
if (isAdmin) {
  const physioRes = await db.execute({
    sql: `SELECT u.userId, u.firstName || ' ' || u.lastName as fullName FROM Users u JOIN Roles r ON u.roleId = r.roleId WHERE r.roleName = 'Fisioterapeuta' ORDER BY u.firstName`,
    args: []
  });
  physios = physioRes.rows;
}

// Lesiones disponibles (se cargan vía JS al seleccionar paciente)
const preselectedPatientId = Astro.url.searchParams.get('patientId') || '';

let error = '';
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const patientId = data.get('patientId') as string;
  const physiotherapistId = (isAdmin ? data.get('physiotherapistId') : String(user?.userId)) as string;
  const injuryId = data.get('injuryId') as string || null;
  const goals = data.get('goals') as string;
  const totalSessionsPlanned = Number(data.get('totalSessionsPlanned') || 0);
  const startDate = data.get('startDate') as string;
  const endDate = data.get('endDate') as string || null;

  if (!patientId || !physiotherapistId || !startDate) {
    error = 'Completa los campos obligatorios: paciente, fecha de inicio.';
  } else {
    // Verificar duplicado
    const dup = await db.execute({
      sql: `SELECT planId FROM PhysiotherapyPlans WHERE patientId = ? AND injuryId IS ? AND status = 'Activo'`,
      args: [patientId, injuryId ?? null]
    });
    if (dup.rows.length > 0) {
      error = `Ya existe un plan activo para este paciente${injuryId ? ' y lesión' : ''}. Actualiza el plan existente.`;
    } else {
      const result = await db.execute({
        sql: `INSERT INTO PhysiotherapyPlans (patientId, physiotherapistId, injuryId, goals, totalSessionsPlanned, startDate, endDate, status, createdBy)
              VALUES (?, ?, ?, ?, ?, ?, ?, 'Activo', ?)`,
        args: [patientId, physiotherapistId, injuryId, goals || null, totalSessionsPlanned, startDate, endDate, user?.userId ?? null]
      });
      await db.execute({
        sql: `INSERT OR IGNORE INTO User_Patient (userId, patientId, roleType) VALUES (?, ?, 'Physiotherapist')`,
        args: [physiotherapistId, patientId]
      });
      return Astro.redirect(`/physiotherapy/${result.lastInsertRowid}`);
    }
  }
}
---

<Layout title="Nuevo Plan de Fisioterapia">
  <div class="mb-6">
    <a href="/physiotherapy" class="text-violet-600 hover:text-violet-700 text-sm font-semibold flex items-center gap-1 mb-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      Volver a Fisioterapia
    </a>
    <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Nuevo Plan de Rehabilitación</h1>
    <p class="text-slate-500 mt-1">Crea un plan de fisioterapia vinculado a un paciente.</p>
  </div>

  {error && (
    <div class="mb-6 p-4 bg-rose-50 border border-rose-200 rounded-2xl text-rose-700 font-medium flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {error}
    </div>
  )}

  <form method="POST" class="glass-card rounded-2xl p-8 border border-white/60 space-y-6 max-w-2xl">
    <!-- Paciente -->
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-2">Paciente <span class="text-rose-500">*</span></label>
      <select id="patientSelect" name="patientId" required class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500">
        <option value="">Selecciona un paciente...</option>
        {patientsRes.rows.map((p: any) => (
          <option value={String(p.patientId)} selected={String(p.patientId) === preselectedPatientId}>{p.fullName}</option>
        ))}
      </select>
    </div>

    <!-- Fisioterapeuta (solo admin) -->
    {isAdmin && (
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Fisioterapeuta <span class="text-rose-500">*</span></label>
        <select name="physiotherapistId" required class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500">
          <option value="">Selecciona un fisioterapeuta...</option>
          {physios.map((p: any) => (
            <option value={String(p.userId)}>{p.fullName}</option>
          ))}
        </select>
      </div>
    )}

    <!-- Lesión relacionada (cargada dinámicamente) -->
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-2">Lesión relacionada <span class="text-slate-400 font-normal">(opcional)</span></label>
      <select id="injurySelect" name="injuryId" class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500">
        <option value="">Sin lesión vinculada</option>
      </select>
      <p id="injuryHint" class="text-xs text-slate-400 mt-1">Selecciona un paciente para ver sus lesiones activas.</p>
    </div>

    <!-- Objetivos -->
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-2">Objetivos del plan</label>
      <textarea name="goals" rows="3" placeholder="Ej: Recuperar rango de movimiento de hombro derecho, reducir dolor a nivel 2/10 en 8 semanas..." class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500 resize-none"></textarea>
    </div>

    <!-- Sesiones Planeadas -->
    <div>
      <label class="block text-sm font-bold text-slate-700 mb-2">Total de sesiones planeadas <span class="text-rose-500">*</span></label>
      <input type="number" name="totalSessionsPlanned" required min="1" max="50" value="10" class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500" />
      <p class="text-xs text-slate-400 mt-1">Número total de sesiones recomendadas para completar el ciclo de rehabilitación.</p>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Fecha de inicio <span class="text-rose-500">*</span></label>
        <input type="date" name="startDate" required value={new Date().toISOString().split('T')[0]} class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Fecha estimada de alta</label>
        <input type="date" name="endDate" class="w-full bg-white/60 border border-slate-200 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-500" />
      </div>
    </div>

    <div class="flex gap-3 pt-2">
      <button type="submit" class="px-6 py-2.5 bg-gradient-to-r from-violet-500 to-purple-600 text-white font-bold rounded-xl shadow-md hover:shadow-lg transition-all">
        Crear Plan
      </button>
      <a href="/physiotherapy" class="px-6 py-2.5 border border-slate-200 text-slate-600 font-semibold rounded-xl hover:bg-slate-50 transition-colors">
        Cancelar
      </a>
    </div>
  </form>
</Layout>

<script>
  // Cargar lesiones dinámicamente al seleccionar paciente
  const patientSelect = document.getElementById('patientSelect') as HTMLSelectElement;
  const injurySelect = document.getElementById('injurySelect') as HTMLSelectElement;
  const injuryHint = document.getElementById('injuryHint');

  patientSelect?.addEventListener('change', async () => {
    const patientId = patientSelect.value;
    if (!patientId) {
      injurySelect.innerHTML = '<option value="">Sin lesión vinculada</option>';
      if (injuryHint) injuryHint.textContent = 'Selecciona un paciente para ver sus lesiones activas.';
      return;
    }

    try {
      const res = await fetch(`/api/patients/search?q=&patientId=${patientId}&injuries=1`);
      // Fallback: consultar directamente injuries del paciente
      const injRes = await fetch(`/api/physiotherapy/plans?patientId=${patientId}`);
      // Simple approach: cargar via endpoint dedicado
      const r = await fetch(`/api/injuries-by-patient?patientId=${patientId}`);
      if (!r.ok) throw new Error();
      const injuries = await r.json();
      injurySelect.innerHTML = '<option value="">Sin lesión vinculada</option>';
      injuries.forEach((inj: any) => {
        const opt = document.createElement('option');
        opt.value = inj.injuryId;
        opt.textContent = `${inj.injuryType} – ${inj.bodyZone} (${inj.status})`;
        injurySelect.appendChild(opt);
      });
      if (injuryHint) injuryHint.textContent = `${injuries.length} lesión(es) encontrada(s)`;
    } catch {
      if (injuryHint) injuryHint.textContent = 'No se pudieron cargar las lesiones.';
    }
  });

  // Si hay paciente preseleccionado, disparar change
  if (patientSelect?.value) patientSelect.dispatchEvent(new Event('change'));
</script>
