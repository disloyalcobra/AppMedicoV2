---
import Layout from '../../layouts/Layout.astro';
import FiltersBar from '../../components/reports/FiltersBar.astro';
import GeneralVision from '../../components/reports/GeneralVision.astro';
import ClinicalModule from '../../components/reports/ClinicalModule.astro';
import PatientsModule from '../../components/reports/PatientsModule.astro';
import InjuriesModule from '../../components/reports/InjuriesModule.astro';
import NutritionModule from '../../components/reports/NutritionModule.astro';
import AlertsModule from '../../components/reports/AlertsModule.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!user || !checkRole(user, [ROLES.ADMINISTRADOR, ROLES.JEFE_MEDICO, ROLES.DOCTOR, ROLES.NUTRIOLOGO, ROLES.ENTRENADOR])) {
  return Astro.redirect('/403');
}

const isAdmin = user.roleId === ROLES.ADMINISTRADOR || user.roleId === ROLES.JEFE_MEDICO;
const isDoctor = user.roleId === ROLES.DOCTOR;
const isNutriciologo = user.roleId === ROLES.NUTRIOLOGO;
const isEntrenador = user.roleId === ROLES.ENTRENADOR;

// Si es admin, cargar la lista de doctores para el filtro
let doctors: any[] = [];
if (isAdmin) {
    const docRes = await db.execute(`
        SELECT u.userId, u.firstName, u.lastName, r.roleName
        FROM Users u
        JOIN Roles r ON u.roleId = r.roleId
        WHERE r.roleName IN ('Doctor', 'Nutriólogo', 'Entrenador')
    `);
    doctors = docRes.rows;
}

// Módulos visibles por rol
const visibleModules = {
    general: true,
    clinical: isDoctor || isAdmin,
    patients: true,
    injuries: isEntrenador || isAdmin || isDoctor,
    nutrition: isNutriciologo || isAdmin,
    alerts: true
};

const visibleModulesJSON = JSON.stringify(visibleModules);
---

<Layout title="Dashboard de Reportes">
  <div class="mb-6 flex flex-col md:flex-row justify-between items-start md:items-end gap-4">
    <div>
      <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">Métricas y Reportes</h1>
      <p class="text-slate-500 mt-1">Análisis visual en tiempo real de la operación clínica.</p>
    </div>
    <FiltersBar isAdmin={isAdmin} doctors={doctors} />
  </div>

  <!-- Loading State -->
  <div id="reportsLoader" class="flex flex-col items-center justify-center py-20 animate-pulse">
      <div class="w-12 h-12 border-4 border-teal-200 border-t-teal-600 rounded-full animate-spin mb-4"></div>
      <p class="text-slate-500 font-medium">Cargando métricas y construyendo gráficos...</p>
  </div>

  <!-- Contenedor Principal (Oculto mientras carga) -->
  <div id="reportsContent" class="space-y-8 hidden opacity-0 transition-opacity duration-500">

      <!-- Navegación por Tabs (Lazy loading visual) -->
      <div id="tabsNav" class="flex overflow-x-auto gap-2 pb-2 scrollbar-hide border-b border-slate-200">
          <button class="tab-btn active px-4 py-2 rounded-t-lg font-bold text-sm text-teal-700 border-b-2 border-teal-600 bg-teal-50" data-target="tab-general">Visión General</button>
          <button class="tab-btn px-4 py-2 rounded-t-lg font-semibold text-sm text-slate-500 hover:text-slate-700 hover:bg-slate-50" data-target="tab-clinical">Clínico</button>
          <button class="tab-btn px-4 py-2 rounded-t-lg font-semibold text-sm text-slate-500 hover:text-slate-700 hover:bg-slate-50" data-target="tab-patients">Pacientes</button>
          <button class="tab-btn px-4 py-2 rounded-t-lg font-semibold text-sm text-slate-500 hover:text-slate-700 hover:bg-slate-50" data-target="tab-injuries">Lesiones</button>
          <button class="tab-btn px-4 py-2 rounded-t-lg font-semibold text-sm text-slate-500 hover:text-slate-700 hover:bg-slate-50" data-target="tab-nutrition">Nutrición</button>
          <button class="tab-btn px-4 py-2 rounded-t-lg font-semibold text-sm text-slate-500 hover:text-slate-700 hover:bg-slate-50" data-target="tab-alerts">Alertas y Notas</button>
      </div>

      <div id="tab-general" class="tab-content block animate-fade-in"><GeneralVision /></div>
      <div id="tab-clinical" class="tab-content hidden"><ClinicalModule /></div>
      <div id="tab-patients" class="tab-content hidden"><PatientsModule /></div>
      <div id="tab-injuries" class="tab-content hidden"><InjuriesModule /></div>
      <div id="tab-nutrition" class="tab-content hidden"><NutritionModule /></div>
      <div id="tab-alerts" class="tab-content hidden"><AlertsModule /></div>
  </div>

</Layout>

<script is:inline define:vars={{ visibleModulesJSON }}>
  window.visibleModules = JSON.parse(visibleModulesJSON);
</script>

<script>
  import Chart from 'chart.js/auto';

  // Exponer Chart globalmente para los modulos
  (window as any).Chart = Chart;

  document.addEventListener('DOMContentLoaded', () => {

    // Ocultar tabs según el rol
    const tabsNav = document.getElementById('tabsNav');
    const vModules = (window as any).visibleModules || {};
    if (tabsNav) {
      const tabs = tabsNav.querySelectorAll('.tab-btn');
      tabs.forEach(tab => {
        const target = tab.getAttribute('data-target')?.replace('tab-', '');
        if (target && !vModules[target]) {
          tab.remove();
        }
      });
    }

    // Tab Navigation Logic
    const tabs = document.querySelectorAll('.tab-btn');
    const contents = document.querySelectorAll('.tab-content');
    
    tabs.forEach(tab => {
        tab.addEventListener('click', () => {
            tabs.forEach(t => {
                t.classList.remove('active', 'text-teal-700', 'border-b-2', 'border-teal-600', 'bg-teal-50');
                t.classList.add('text-slate-500');
            });
            contents.forEach(c => c.classList.add('hidden', 'animate-fade-in'));
            
            tab.classList.remove('text-slate-500');
            tab.classList.add('active', 'text-teal-700', 'border-b-2', 'border-teal-600', 'bg-teal-50');
            
            const targetId = tab.getAttribute('data-target');
            document.getElementById(targetId || '')?.classList.remove('hidden');
        });
    });

    // Core Fetch Logic
    const filterRange = document.getElementById('filterRange') as HTMLSelectElement;
    const filterDoctor = document.getElementById('filterDoctor') as HTMLSelectElement;
    let currentData: any = null;

    const fetchReports = async () => {
        const loader = document.getElementById('reportsLoader');
        const content = document.getElementById('reportsContent');
        if(!loader || !content) return;
        
        content.classList.add('opacity-0');
        setTimeout(() => content.classList.add('hidden'), 300);
        loader.classList.remove('hidden');

        try {
            const range = filterRange?.value || 'month';
            const doctorId = filterDoctor?.value || '';
            
            const response = await fetch(`/api/reports?range=${range}&doctorId=${doctorId}`);
            
            if (!response.ok) {
                throw new Error("Error en la respuesta del servidor");
            }
            
            currentData = await response.json();
            
            // Disparar evento global para que los componentes dibujen sus gráficos
            const event = new CustomEvent('reportsDataLoaded', { detail: currentData });
            window.dispatchEvent(event);
            
            setTimeout(() => {
                loader.classList.add('hidden');
                content.classList.remove('hidden');
                // Trigger reflow
                void content.offsetWidth;
                content.classList.remove('opacity-0');
            }, 100);
        } catch (error) {
            console.error('Error fetching reports:', error);
            loader.innerHTML = '<p class="text-rose-500 font-bold">Error al cargar datos. Intente nuevamente.</p>';
        }
    };

    filterRange?.addEventListener('change', fetchReports);
    filterDoctor?.addEventListener('change', fetchReports);

    // Initial Fetch
    fetchReports();


  });
</script>
