---
import AuthLayout from '../layouts/AuthLayout.astro';
import { ROLES, checkRole } from '../functions/checkRole';

// Protect this route - only admins can register new users
const user = Astro.locals.user;
if (!user || user.roleId !== ROLES.ADMINISTRADOR) {
  return Astro.redirect('/');
}

let error = '';
let success = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    // In a real app, you would insert into Turso here
    success = 'Usuario registrado exitosamente (Mock).';
  } catch (e) {
    if (e instanceof Error) {
      error = e.message;
    }
  }
}
---

<AuthLayout title="Registrar Usuario">
  <div class="glass-strong rounded-2xl p-8 shadow-2xl w-full max-w-md animate-scale-in relative">
    <a href="/" class="absolute top-6 left-6 text-slate-400 hover:text-slate-600 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </a>

    <div class="w-16 h-16 bg-gradient-to-br from-teal-500 to-sky-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" x2="19" y1="8" y2="14"/><line x1="22" x2="16" y1="11" y2="11"/></svg>
    </div>
    
    <h1 class="text-2xl font-bold text-center text-slate-800 mb-2 tracking-tight">Registrar Usuario</h1>
    <p class="text-center text-slate-500 mb-8 text-sm">Solo administradores pueden crear cuentas</p>
    
    {error && (
      <div class="bg-rose-50 border border-rose-200 text-rose-600 px-4 py-3 rounded-lg text-sm mb-6 animate-fade-in shadow-sm">
        {error}
      </div>
    )}
    
    {success && (
      <div class="bg-emerald-50 border border-emerald-200 text-emerald-600 px-4 py-3 rounded-lg text-sm mb-6 animate-fade-in shadow-sm">
        {success}
      </div>
    )}

    <form method="POST" class="space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label for="firstName" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Nombre</label>
          <input type="text" name="firstName" id="firstName" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
        </div>
        <div>
          <label for="lastName" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Apellido</label>
          <input type="text" name="lastName" id="lastName" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
        </div>
      </div>

      <div>
        <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Correo Electrónico</label>
        <input type="email" name="email" id="email" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
      </div>

      <div>
        <label for="roleId" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Rol</label>
        <select name="roleId" id="roleId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
          <option value="1">Administrador</option>
          <option value="2">Jefe Médico</option>
          <option value="3">Doctor</option>
          <option value="4">Nutriólogo</option>
          <option value="5">Estudiante</option>
          <option value="6">Staff</option>
          <option value="7">Entrenador</option>
        </select>
      </div>
      
      <div>
        <label for="password" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Contraseña</label>
        <input type="password" name="password" id="password" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
      </div>
      
      <button type="submit" class="w-full bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-semibold py-3.5 px-4 rounded-xl shadow-md hover:shadow-lg transform transition-all active:scale-[0.98] mt-4">
        Crear Usuario
      </button>
    </form>
  </div>
</AuthLayout>
