---
import AuthLayout from '../layouts/AuthLayout.astro';
import { db } from '../turso';
import { ROLES } from '../functions/checkRole';
import bcrypt from 'bcryptjs';

let error = '';
let success = '';

interface Coach {
  userId: number;
  firstName: string;
  lastName: string;
}

const coachesRes = await db.execute({
  sql: `SELECT userId, firstName, lastName FROM Users WHERE roleId = ?`,
  args: [ROLES.ENTRENADOR]
});
const coaches: Coach[] = coachesRes.rows.map((r: any) => ({
  userId: Number(r.userId),
  firstName: String(r.firstName),
  lastName: String(r.lastName),
}));

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const firstName = data.get('firstName') as string;
    const lastName = data.get('lastName') as string;
    const matricula = data.get('matricula') as string;
    const email = data.get('email') as string;
    const password = data.get('password') as string;
    const gender = data.get('gender') as string;
    const dateOfBirth = data.get('dateOfBirth') as string;
    const bloodType = data.get('bloodType') as string;
    const weight = data.get('weight') ? Number(data.get('weight')) : null;
    const height = data.get('height') ? Number(data.get('height')) : null;
    const allergies = data.get('allergies') as string;
    const schoolLevel = data.get('schoolLevel') as string;
    const isAthlete = data.get('isAthlete') === '1' ? 1 : 0;
    const coachId = data.get('coachId') ? Number(data.get('coachId')) : null;

    if (!matricula || !email || !password || !firstName || !lastName || !gender || !dateOfBirth) {
      error = 'Por favor completa todos los campos obligatorios.';
    } else {
      // Check if email already exists
      const existingEmail = await db.execute({
        sql: `SELECT userId FROM Users WHERE email = ? LIMIT 1`,
        args: [email]
      });

      if (existingEmail.rows.length > 0) {
        error = 'Este correo ya está registrado. Por favor inicia sesión.';
      } else {
        const salt = await bcrypt.genSalt(10);
        const passwordHash = await bcrypt.hash(password, salt);

        // Create User and Patient with all medical data
        await db.batch([
          {
            sql: `INSERT INTO Users (firstName, lastName, email, password, roleId, matricula) VALUES (?, ?, ?, ?, ?, ?)`,
            args: [firstName, lastName, email, passwordHash, ROLES.ESTUDIANTE, matricula]
          },
          {
            sql: `INSERT INTO Patients (patientId, dateOfBirth, gender, bloodType, allergies, weight, height, isAthlete, schoolLevel)
                  VALUES (last_insert_rowid(), ?, ?, ?, ?, ?, ?, ?, ?)`,
            args: [dateOfBirth, gender, bloodType, allergies, weight, height, isAthlete, schoolLevel]
          }
        ], "write");

        if (isAthlete === 1 && coachId) {
            const patientIdResult = await db.execute({ sql: `SELECT userId FROM Users WHERE email = ?`, args: [email]});
            if(patientIdResult.rows.length > 0) {
               const newPatientId = Number(patientIdResult.rows[0].userId);
               await db.execute({
                sql: `INSERT INTO User_Patient (userId, patientId, roleType) VALUES (?, ?, 'Coach')`,
                args: [coachId, newPatientId]
               });
            }
        }

        success = 'Cuenta creada exitosamente. Ya puedes iniciar sesión.';
      }
    }
  } catch (e) {
    if (e instanceof Error) {
        error = e.message;
        if (error.includes('Users.matricula')) {
          error = 'Esta matricula ya esta registrada. Por favor contacta al servicio medico.';
        } else if (error.includes('Users.email')) {
          error = 'Este correo ya esta registrado.';
        }
        console.error('Registration error:', e);
    }
  }
}
---

<AuthLayout title="Registro de Alumno">
  <div class="glass-strong rounded-2xl p-8 shadow-2xl w-full max-w-2xl animate-scale-in relative my-8">
    <a href="/login" class="absolute top-6 left-6 text-slate-400 hover:text-slate-600 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    </a>

    <div class="w-16 h-16 bg-gradient-to-br from-teal-500 to-emerald-500 rounded-2xl flex items-center justify-center mx-auto mb-6 shadow-lg">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 10v6"/><path d="M19 13h6"/></svg>
    </div>

    <h1 class="text-2xl font-bold text-center text-slate-800 mb-2 tracking-tight">Registro de Alumno</h1>
    <p class="text-center text-slate-500 mb-8 text-sm">Completa tu perfil para el sistema medico</p>

    {error && (
      <div class="bg-rose-50 border border-rose-200 text-rose-600 px-4 py-3 rounded-xl text-sm mb-6 animate-fade-in shadow-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {error}
      </div>
    )}

    {success && (
      <div class="bg-emerald-50 border border-emerald-200 text-emerald-600 px-4 py-3 rounded-xl text-sm mb-6 animate-fade-in shadow-sm flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        {success}
        <a href="/login" class="ml-auto font-bold underline">Ir al Login</a>
      </div>
    )}

    <form method="POST" class="space-y-6">
      {/* Datos Basicos */}
      <div class="bg-white/40 rounded-xl p-5 border border-white/60">
        <h3 class="text-sm font-bold text-slate-700 mb-4 uppercase tracking-wide">Datos Basicos</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label for="firstName" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Nombre(s) *</label>
            <input type="text" name="firstName" id="firstName" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
          </div>
          <div>
            <label for="lastName" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Apellidos *</label>
            <input type="text" name="lastName" id="lastName" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
          </div>
          <div>
            <label for="matricula" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Matricula / ID Institucional *</label>
            <input type="text" name="matricula" id="matricula" placeholder="Ej. 20240001" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 font-mono" required />
          </div>
          <div>
            <label for="dateOfBirth" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Fecha de Nacimiento *</label>
            <input type="date" name="dateOfBirth" id="dateOfBirth" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
          </div>
          <div>
            <label for="gender" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Genero *</label>
            <select name="gender" id="gender" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required>
              <option value="">Selecciona...</option>
              <option value="M">Masculino</option>
              <option value="F">Femenino</option>
              <option value="X">Otro</option>
            </select>
          </div>
          <div>
            <label for="schoolLevel" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Nivel Escolar</label>
            <select name="schoolLevel" id="schoolLevel" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500">
              <option value="">Selecciona Nivel</option>
              <option value="Primaria">Primaria</option>
              <option value="Secundaria">Secundaria</option>
              <option value="Preparatoria">Preparatoria</option>
              <option value="Universidad">Universidad</option>
            </select>
          </div>
        </div>
      </div>

      {/* Datos de Cuenta */}
      <div class="bg-white/40 rounded-xl p-5 border border-white/60">
        <h3 class="text-sm font-bold text-slate-700 mb-4 uppercase tracking-wide">Datos de Cuenta</h3>
        <div class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Correo Electronico *</label>
            <input type="email" name="email" id="email" placeholder="alumno@universidad.edu" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
          </div>
          <div>
            <label for="password" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Contrasena *</label>
            <input type="password" name="password" id="password" placeholder="Minimo 6 caracteres" minlength="6" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" required />
          </div>
        </div>
      </div>

      {/* Datos Medicos */}
      <div class="bg-white/40 rounded-xl p-5 border border-white/60">
        <h3 class="text-sm font-bold text-slate-700 mb-4 uppercase tracking-wide">Datos Medicos</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <div>
            <label for="bloodType" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Tipo de Sangre</label>
            <select name="bloodType" id="bloodType" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500">
              <option value="">Desconocido</option>
              <option value="A+">A+</option>
              <option value="A-">A-</option>
              <option value="B+">B+</option>
              <option value="B-">B-</option>
              <option value="AB+">AB+</option>
              <option value="AB-">AB-</option>
              <option value="O+">O+</option>
              <option value="O-">O-</option>
            </select>
          </div>
          <div>
            <label for="weight" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Peso (kg)</label>
            <input type="number" step="0.1" name="weight" id="weight" placeholder="Ej. 70.5" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" />
          </div>
          <div>
            <label for="height" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Altura (cm)</label>
            <input type="number" step="0.1" name="height" id="height" placeholder="Ej. 175" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" />
          </div>
          <div class="md:col-span-3">
            <label for="allergies" class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Alergias Conocidas</label>
            <textarea name="allergies" id="allergies" rows="2" class="w-full bg-white/70 border border-slate-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500" placeholder="Ej: Penicilina, Nueces, Mariscos... (Dejar en blanco si ninguna)"></textarea>
          </div>
        </div>
      </div>

      {/* Perfil de Atleta */}
      <div class="bg-amber-50/50 rounded-xl p-5 border border-amber-200/60">
        <div class="flex items-center justify-between">
          <div>
            <h3 class="text-sm font-bold text-amber-800 uppercase tracking-wide">Perfil de Atleta</h3>
            <p class="text-xs text-amber-700/80 mt-1">Activa esta opcion si participas en actividades deportivas</p>
          </div>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" name="isAthlete" value="1" class="sr-only peer" id="isAthleteToggle">
            <div class="w-11 h-6 bg-slate-200 peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-amber-300 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-amber-500"></div>
          </label>
        </div>

        <div id="coachSelection" class="hidden border-t border-amber-200/60 pt-4 mt-4">
            <label for="coachId" class="block text-sm font-semibold text-amber-900 mb-1.5 ml-1">Selecciona tu Entrenador</label>
            <select name="coachId" id="coachId" class="w-full bg-white/70 border border-amber-200/60 rounded-xl px-4 py-2.5 text-slate-800 focus:outline-none focus:ring-2 focus:ring-amber-500">
              <option value="">No tengo entrenador asignado / No sé</option>
              {coaches.map(coach => (
                <option value={coach.userId}>{coach.firstName} {coach.lastName}</option>
              ))}
            </select>
        </div>
      </div>

      <button type="submit" class="w-full bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-bold py-3.5 px-4 rounded-xl shadow-md hover:shadow-lg transform transition-all active:scale-[0.98]">
        Completar Registro
      </button>

      <div class="text-center">
        <p class="text-sm text-slate-500">
          Ya tienes cuenta? <a href="/login" class="text-teal-600 font-bold hover:underline">Inicia Sesion</a>
        </p>
      </div>
    </form>
  </div>
</AuthLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('isAthleteToggle') as HTMLInputElement;
    const coachSelection = document.getElementById('coachSelection');
    
    if(toggle && coachSelection) {
      toggle.addEventListener('change', (e) => {
        if ((e.target as HTMLInputElement).checked) {
          coachSelection.classList.remove('hidden');
        } else {
          coachSelection.classList.add('hidden');
        }
      });
    }
  });
</script>
