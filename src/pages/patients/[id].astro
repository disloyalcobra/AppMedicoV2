---
/**
 * HUB CENTRAL DEL PACIENTE (Expediente Clínico)
 * Esta es la página más compleja del sistema. Gestiona la visualización de:
 * 1. Datos personales del paciente.
 * 2. Historial de Citas.
 * 3. Historial de Consultas Médicas.
 * 4. Recetas Activas.
 * 5. Historial de Lesiones.
 */
import Layout from "../../layouts/Layout.astro";
import { ROLES, checkRole } from "../../functions/checkRole";
import { db } from "../../turso";

// 1. SEGURIDAD DE RUTA: Usuarios permitidos según el Middleware
const user = Astro.locals.user;
if (
  !checkRole(user, [
    ROLES.DOCTOR,
    ROLES.JEFE_MEDICO,
    ROLES.NUTRIOLOGO,
    ROLES.ENTRENADOR,
    ROLES.FISIOTERAPEUTA,
    ROLES.ADMINISTRADOR,
    ROLES.ESTUDIANTE,
  ])
) {
  return Astro.redirect("/403");
}

const { id } = Astro.params;
if (!id) return Astro.redirect("/404");

const roleId = Number(user?.roleId);

// 2. SEGURIDAD DE DATOS (Ownership): Un estudiante solo puede ver SU propio ID.
if (user?.roleId === ROLES.ESTUDIANTE && String(user.userId) !== String(id)) {
  return Astro.redirect("/403");
}

// 3. SEGURIDAD RBAC (Ownership Clínico): Un doctor/nutriologo solo puede ver a sus pacientes vinculados
let requiredRoleType = "";
if (user?.roleId === ROLES.DOCTOR) requiredRoleType = "Doctor";
else if (user?.roleId === ROLES.NUTRIOLOGO) requiredRoleType = "Nutritionist";
else if (user?.roleId === ROLES.ENTRENADOR) requiredRoleType = "Coach";
else if (user?.roleId === ROLES.FISIOTERAPEUTA) requiredRoleType = "Physiotherapist";

if (requiredRoleType && user) {
  const accessCheck = await db.execute({
    sql: `SELECT 1 FROM User_Patient WHERE userId = ? AND patientId = ? AND roleType = ?`,
    args: [user.userId, id, requiredRoleType]
  });
  if (accessCheck.rows.length === 0) {
    return Astro.redirect("/403");
  }
}

// --- OBTENCIÓN DE DATOS DESDE TURSO ---

// A. Información básica del Paciente y Usuario
const patientResult = await db.execute({
  sql: `SELECT p.patientId, u.firstName, u.lastName, p.dateOfBirth, p.bloodType, p.allergies, p.weight, p.height, p.isAthlete, p.gender, p.schoolLevel
        FROM Patients p JOIN Users u ON p.patientId = u.userId 
        WHERE p.patientId = ?`,
  args: [id],
});

if (patientResult.rows.length === 0) {
  return Astro.redirect("/404");
}

const pData = patientResult.rows[0];
const dob = new Date(String(pData.dateOfBirth || ""));
// Cálculo de edad dinámica basada en fecha de nacimiento
const age = Math.abs(
  new Date(Date.now() - dob.getTime()).getUTCFullYear() - 1970,
);

const patient = {
  id: pData.patientId,
  firstName: pData.firstName,
  lastName: pData.lastName,
  age,
  bloodType: pData.bloodType || "N/A",
  allergies: pData.allergies || "Ninguna",
  weight: pData.weight ? `${pData.weight} kg` : "N/A",
  height: pData.height ? `${pData.height} cm` : "N/A",
  isAthlete: pData.isAthlete,
  gender: pData.gender || "O",
  schoolLevel: pData.schoolLevel || "",
};

// B. Citas Médicas (Ordenadas por fecha descendente)
let aptQuery = `SELECT a.appointmentId as id, a.dateTime as date, u.firstName || ' ' || u.lastName as doctor, a.status, a.appointmentType
        FROM Appointments a JOIN Users u ON a.specialistId = u.userId
        WHERE a.patientId = ?`;
let aptArgs: any[] = [id];

if (roleId === ROLES.DOCTOR || roleId === ROLES.NUTRIOLOGO || roleId === ROLES.FISIOTERAPEUTA) {
    aptQuery += ` AND a.specialistId = ?`;
    aptArgs.push(user?.userId);
}
aptQuery += ` ORDER BY a.dateTime DESC`;

const aptResult = await db.execute({ sql: aptQuery, args: aptArgs });
const appointments = aptResult.rows.map((r) => ({
  id: r.id,
  date: String(r.date),
  doctor: (r.appointmentType === 'Nutricion' ? "Nut. " : r.appointmentType === 'Fisioterapia' ? "Fis. " : "Dr. ") + r.doctor,
  status: r.status,
  reason: "Sin motivo",
  type: r.appointmentType
}));

// C. Consultas Médicas (Incluyendo conteo de sub-elementos vía sub-queries)
const consResult = await db.execute({
  sql: `SELECT c.consultationId as id, c.consultationDate as date, c.diagnosis, 
        (SELECT COUNT(*) FROM Prescriptions WHERE consultationId = c.consultationId) as prescriptionsCount,
        (SELECT COUNT(*) FROM ClinicalFiles WHERE consultationId = c.consultationId) as filesCount
        FROM Consultations c JOIN Appointments a ON c.appointmentId = a.appointmentId 
        WHERE a.patientId = ? ORDER BY c.consultationDate DESC`,
  args: [id],
});
const consultations = consResult.rows;


// E. Historial de Lesiones
const injResult = await db.execute({
  sql: `SELECT injuryId as id, injuryDate as date, injuryType as type, bodyZone as zone, severity, status, campusLocation as campus 
        FROM Injuries WHERE patientId = ? ORDER BY injuryDate DESC`,
  args: [id],
});
const injuries = injResult.rows;

// F. Notas Colaborativas y Alertas (Nueva funcionalidad)
const notesResult = await db.execute({
  sql: `SELECT n.noteId as id, n.noteContent as content, n.isAlert, n.alertTags as tags, n.createdAt, n.status,
               u.firstName || ' ' || u.lastName as author, r.roleName as authorRole
        FROM CollaborativeNotes n 
        JOIN Users u ON n.authorId = u.userId 
        JOIN Roles r ON u.roleId = r.roleId
        WHERE n.patientId = ? 
        ORDER BY n.createdAt DESC`,
  args: [id],
});
const allNotes = notesResult.rows;

// G. Verificación de Vínculo (Seguridad de visibilidad)
let isLinkedDoctor = false;
let isLinkedCoach = false;
let isLinkedPhysio = false;
if (user?.roleId === ROLES.DOCTOR) {
  const linkRes = await db.execute({
    sql: `SELECT 1 FROM User_Patient WHERE userId = ? AND patientId = ? AND roleType = 'Doctor' LIMIT 1`,
    args: [user.userId, id]
  });
  isLinkedDoctor = linkRes.rows.length > 0;
} else if (user?.roleId === ROLES.ENTRENADOR) {
  const linkRes = await db.execute({
    sql: `SELECT 1 FROM User_Patient WHERE userId = ? AND patientId = ? AND roleType = 'Coach' LIMIT 1`,
    args: [user.userId, id]
  });
  isLinkedCoach = linkRes.rows.length > 0;
} else if (user?.roleId === ROLES.FISIOTERAPEUTA) {
  const linkRes = await db.execute({
    sql: `SELECT 1 FROM User_Patient WHERE userId = ? AND patientId = ? AND roleType = 'Physiotherapist' LIMIT 1`,
    args: [user.userId, id]
  });
  isLinkedPhysio = linkRes.rows.length > 0;
}

// --- CONFIGURACIÓN DE PERMISOS DE INTERFAZ ---
const isDoctorOrAdmin =
  user?.roleId === ROLES.DOCTOR ||
  user?.roleId === ROLES.ADMINISTRADOR ||
  user?.roleId === ROLES.JEFE_MEDICO;

const isAdmin = 
  user?.roleId === ROLES.ADMINISTRADOR ||
  user?.roleId === ROLES.JEFE_MEDICO;

const isNutritionist = user?.roleId === ROLES.NUTRIOLOGO;

const canSeeNotes =
  user?.roleId === ROLES.ADMINISTRADOR ||
  user?.roleId === ROLES.JEFE_MEDICO ||
  isLinkedDoctor ||
  isLinkedCoach ||
  isLinkedPhysio ||
  isNutritionist;

const isFisioterapeuta = user?.roleId === ROLES.FISIOTERAPEUTA;

let activePlanId: number | null = null;
if (user?.roleId === ROLES.ESTUDIANTE) {
  const nutPlanRes = await db.execute({
    sql: `SELECT planId FROM NutritionalPlans WHERE patientId = ? ORDER BY creationDate DESC LIMIT 1`,
    args: [id]
  });
  if (nutPlanRes.rows.length > 0) {
    activePlanId = Number(nutPlanRes.rows[0].planId);
  }
}

// J. Plan de Fisioterapia
const physioPlanRes = await db.execute({
  sql: `SELECT planId, status, goals FROM PhysiotherapyPlans WHERE patientId = ? AND status = 'Activo' LIMIT 1`,
  args: [id]
});
const activePhysioPlan = (physioPlanRes.rows[0] as any) ?? null;

// isNutritionist e isDoctorOrAdmin ya se declararon arriba junto a canSeeNotes

const canAddNotes =
  user?.roleId === ROLES.DOCTOR ||
  user?.roleId === ROLES.ADMINISTRADOR ||
  user?.roleId === ROLES.JEFE_MEDICO ||
  user?.roleId === ROLES.NUTRIOLOGO ||
  user?.roleId === ROLES.ENTRENADOR ||
  user?.roleId === ROLES.FISIOTERAPEUTA;
const isStudent = Number(user?.roleId) === ROLES.ESTUDIANTE;
const isOwnProfile = Number(user?.userId) === Number(id);
const canSeePhysio = isFisioterapeuta || isAdmin || (isStudent && isOwnProfile);

// Cargar planes de fisioterapia del paciente
const physioPlansRes = await db.execute({
  sql: `SELECT pp.planId, pp.goals, pp.startDate, pp.status,
               ph.firstName || ' ' || ph.lastName as physioName,
               i.injuryType, i.bodyZone,
               (SELECT COUNT(*) FROM PhysiotherapySessions WHERE planId = pp.planId AND status = 'Completada') as completedSessions,
               (SELECT COUNT(*) FROM PhysiotherapySessions WHERE planId = pp.planId) as totalSessions
        FROM PhysiotherapyPlans pp
        JOIN Users ph ON pp.physiotherapistId = ph.userId
        LEFT JOIN Injuries i ON pp.injuryId = i.injuryId
        WHERE pp.patientId = ?
        ORDER BY pp.startDate DESC LIMIT 5`,
  args: [id]
});
const physioPlans = physioPlansRes.rows;

// --- PROCESAMIENTO DE ACCIONES (POST) ---
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('_action');

  if (action === 'addNote' && canAddNotes) {
    const content = data.get('content') as string;
    const isAlert = data.get('isAlert') === 'on' ? 1 : 0;
    const tags = data.get('tags') as string;

    await db.execute({
      sql: `INSERT INTO CollaborativeNotes (patientId, authorId, noteContent, isAlert, alertTags, status) VALUES (?, ?, ?, ?, ?, 'active')`,
      args: [id, user?.userId, content, isAlert, tags]
    });
    return Astro.redirect(`/patients/${id}`);
  }

  if (action === 'dismissAlert') {
    const noteId = String(data.get('noteId') || "");
    await db.execute({
      sql: `UPDATE CollaborativeNotes SET status = 'dismissed' WHERE noteId = ?`,
      args: [noteId]
    });
    return Astro.redirect(`/patients/${id}`);
  }
}

// Definición de íconos SVG para uso repetitivo en el template
const ICONS = {
  plus: '<path d="M5 12h14"/><path d="M12 5v14"/>',
  edit: '<path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>',
  trash:
    '<path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/>',
  eye: '<path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/>',
  alert: '<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
};
---

<Layout title={`Expediente: ${patient.firstName} ${patient.lastName}`}>
  {/* CABECERA: Nombre y Acciones de Edición */}
  <div class="mb-6 flex justify-between items-end">
    <div>
      <a
        href="/patients"
        class="text-teal-600 hover:text-teal-700 text-sm font-semibold flex items-center gap-1 mb-2"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
        >
        Volver a Pacientes
      </a>
      <h1
        class="text-3xl font-bold text-slate-800 tracking-tight flex items-center gap-3"
      >
        {patient.firstName}
        {patient.lastName}
        {
          patient.isAthlete === 1 && (
            <span class="bg-amber-100 text-amber-800 text-[10px] sm:text-xs font-bold px-2 py-1 rounded-full border border-amber-200 uppercase tracking-widest align-middle">
              Atleta
            </span>
          )
        }
      </h1>
    </div>

    <div class="flex gap-2">
      {
        /* Solo los doctores o admin pueden editar los datos demográficos básicos */
      }
      {
        isDoctorOrAdmin && (
          <a
            href={`/patients/edit/${patient.id}`}
            class="px-4 py-2 bg-slate-50 border border-slate-200 text-slate-700 font-semibold rounded-xl text-sm hover:bg-slate-100 transition-colors flex items-center gap-1.5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z" />
            </svg>
            Editar Datos
          </a>
        )
      }
      {
        /* Nutriólogo puede crear evaluación nutricional desde el perfil del paciente */
      }
      {
        isNutritionist && (
          <a
            href={`/nutrition/profiles/add?patientId=${patient.id}`}
            class="px-4 py-2 bg-emerald-50 border border-emerald-200 text-emerald-700 font-semibold rounded-xl text-sm hover:bg-emerald-100 transition-colors flex items-center gap-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Nueva Evaluación Nutricional
          </a>
        )
      }
      {
        canAddNotes && (
          <button
            id="openNoteModal"
            class="px-4 py-2 bg-rose-50 border border-rose-200 text-rose-700 font-semibold rounded-xl text-sm hover:bg-rose-100 transition-colors flex items-center gap-1.5"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m11 2 4 2 2 4v14H5V4l2-2z"/><path d="M19 14H5"/><path d="M12 14v4"/><path d="M10 18h4"/></svg>
            Alertas y Notas
          </button>
        )
      }
    </div>
  </div>

  {/* BANNER DE ALERTAS DINÁMICAS (CollaborativeNotes where isAlert=1 and status='active') */}
  {
    allNotes.filter(n => n.isAlert === 1 && n.status === 'active').length > 0 && (
      <div class="mb-8 space-y-3">
        {allNotes.filter(n => n.isAlert === 1 && n.status === 'active').map(alert => (
          <div class="flex items-start gap-4 p-4 bg-rose-50 border border-rose-200 rounded-2xl shadow-sm animate-in fade-in slide-in-from-left-4 group/alert">
             <div class="mt-1 p-2 bg-rose-100 text-rose-600 rounded-lg animate-pulse">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                </svg>
             </div>
             <div class="flex-1">
                <div class="flex justify-between items-start">
                  <h4 class="font-bold text-rose-900 text-sm italic uppercase tracking-wider">Alerta Médica: {alert.tags}</h4>
                  <div class="flex items-center gap-3">
                    <span class="text-[10px] text-rose-500 font-bold uppercase">{String(alert.createdAt).split(' ')[0]}</span>
                    {canAddNotes && (
                      <form method="POST" class="opacity-0 group-hover/alert:opacity-100 transition-opacity">
                        <input type="hidden" name="_action" value="dismissAlert" />
                        <input type="hidden" name="noteId" value={String(alert.id)} />
                        <button type="submit" class="p-1 bg-rose-100 text-rose-700 hover:bg-rose-200 rounded-md transition-colors" title="Quitar de alertas">
                          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                        </button>
                      </form>
                    )}
                  </div>
                </div>
                <p class="text-rose-800 text-md mt-1 font-medium">{alert.content}</p>
                <p class="text-[11px] text-rose-400 mt-2">— Reportado por {alert.author} ({alert.authorRole})</p>
             </div>
          </div>
        ))}
      </div>
    )
  }

  {/* CAJA DE DATOS RÁPIDOS: Resumen médico preventivo */}
  <div
    class="glass-card rounded-2xl p-6 mb-8 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4"
  >
    <div>
      <p
        class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
      >
        Edad
      </p>
      <p class="font-bold text-slate-800 text-lg">{patient.age} años</p>
    </div>
    <div>
      <p
        class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
      >
        Peso / Altura
      </p>
      <p class="font-bold text-slate-800 text-lg">
        {patient.weight} / {patient.height}
      </p>
    </div>
    <div>
      <p
        class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
      >
        Sangre
      </p>
      <p class="font-bold text-rose-600 text-lg">{patient.bloodType}</p>
    </div>
    <div class="lg:col-span-2">
      <p
        class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1"
      >
        Alergias
      </p>
      <p class="font-bold text-amber-600 text-sm md:text-md">
        {patient.allergies}
      </p>
    </div>
    <div>
      {
        patient.isAthlete === 1 && (
          <>
            <p class="text-slate-400 text-xs uppercase tracking-wider font-semibold mb-1">
              Perfil
            </p>
            <p class="font-bold text-amber-700 text-lg">Deportista</p>
          </>
        )
      }
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-2 gap-8">
    {/* SECCIÓN CITAS: Visible para todos los roles con permisos de agenda */}
    {(isDoctorOrAdmin || isNutritionist || isFisioterapeuta || isStudent) && (
    <div class="glass-card rounded-2xl p-6">
      <div
        class="flex items-center justify-between mb-4 border-b border-white/40 pb-4"
      >
        <h3 class="text-xl font-bold text-slate-800">Citas</h3>
        {
          (isDoctorOrAdmin || isStudent || isNutritionist || isFisioterapeuta) && (
            <a
              href={`/appointments/add?patientId=${patient.id}`}
              class="flex items-center gap-1 text-sm bg-teal-50 text-teal-700 px-3 py-1.5 rounded-lg border border-teal-200 font-semibold hover:bg-teal-500 hover:text-white transition-colors"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={ICONS.plus}
              />
              {isStudent ? "Agendar Cita" : "Nueva Cita"}
            </a>
          )
        }
      </div>
      <div class="space-y-3">
        {
          appointments.length > 0 ? (
            appointments.map((apt) => (
              <div class="p-4 bg-white/40 rounded-xl border border-white/60 flex justify-between items-center group">
                <div class="max-w-[60%]">
                  <p class="font-bold text-slate-800 text-sm">{apt.date}</p>
                  <p class="text-[11px] text-teal-700 font-bold uppercase mt-0.5">{apt.doctor}</p>
                  {apt.reason && (
                    <p class="text-[10px] text-slate-500 italic truncate mt-1">"{apt.reason}"</p>
                  )}
                </div>
                <div class="flex items-center gap-4">
                  <span
                    class={`px-2.5 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider border ${
                      apt.status === "Confirmada"
                        ? "bg-emerald-50 text-emerald-700 border-emerald-200"
                        : apt.status === "Rechazada" || apt.status === "Cancelada"
                        ? "bg-rose-50 text-rose-700 border-rose-200"
                        : "bg-amber-50 text-amber-700 border-amber-200"
                    }`}
                  >
                    {apt.status}
                  </span>
                  {(isDoctorOrAdmin || isStudent) && (
                    <a
                      href={`/appointments/${apt.id}`}
                      class="text-slate-400 hover:text-teal-600 transition-colors opacity-0 group-hover:opacity-100 p-1"
                      title="Ver Detalles"
                    >
                      <svg
                        class="w-4 h-4"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={isDoctorOrAdmin ? ICONS.edit : ICONS.eye}
                      />
                    </a>
                  )}
                </div>
              </div>
            ))
          ) : (
            <div class="text-sm text-slate-500 py-2">
              No hay citas registradas.
            </div>
          )
        }
      </div>
    </div>
    )}

    {/* SECCIÓN CONSULTAS: Oculta para nutriólogo y fisioterapeuta */}
    {!isNutritionist && !isFisioterapeuta && (
    <div class="glass-card rounded-2xl p-6">
      <div
        class="flex items-center justify-between mb-4 border-b border-white/40 pb-4"
      >
        <h3 class="text-xl font-bold text-slate-800">Consultas</h3>
        {
          isDoctorOrAdmin && (
            <a
              href={`/consultations/add?patientId=${patient.id}`}
              class="flex items-center gap-1 text-sm bg-teal-50 text-teal-700 px-3 py-1.5 rounded-lg border border-teal-200 font-semibold hover:bg-teal-500 hover:text-white transition-colors"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={ICONS.plus}
              />
              Nueva Consulta
            </a>
          )
        }
      </div>
      <div class="space-y-3">
        {
          consultations.length > 0 ? (
            consultations.map((cons) => (
              <div class="p-4 bg-white/40 rounded-xl border border-white/60 group">
                <div class="flex justify-between items-start mb-2">
                  <p class="font-bold text-slate-800 text-sm">{cons.date}</p>
                  {isDoctorOrAdmin ? (
                    <a
                      href={`/consultations/${cons.id}`}
                      class="text-xs font-semibold text-teal-600 hover:text-teal-800 bg-white px-2 py-1 rounded shadow-sm border border-slate-100 flex items-center gap-1"
                    >
                      <svg
                        class="w-3 h-3"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={ICONS.edit}
                      />{" "}
                      Ver/Editar
                    </a>
                  ) : (
                    <a
                      href={`/consultations/${cons.id}`}
                      class="text-xs font-semibold text-slate-500 hover:text-teal-600 flex items-center gap-1"
                    >
                      <svg
                        class="w-3 h-3"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={ICONS.eye}
                      />{" "}
                      Ver
                    </a>
                  )}
                </div>
                <p class="text-sm text-slate-600 line-clamp-2">
                  {cons.diagnosis}
                </p>
                <div class="mt-3 flex gap-3 text-xs text-slate-400 font-medium">
                  <span class="flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-indigo-400" />{" "}
                    {cons.prescriptionsCount} Recetas
                  </span>
                  <span class="flex items-center gap-1">
                    <span class="w-2 h-2 rounded-full bg-slate-400" />{" "}
                    {cons.filesCount} Archivos
                  </span>
                </div>
              </div>
            ))
          ) : (
            <div class="text-sm text-slate-500 py-2">
              No hay consultas registradas.
            </div>
          )
        }
      </div>
    </div>
    )}


    {/* SECCIÓN NOTAS MÉDICAS: Seguimiento colaborativo entre doctores */}
    {
      canSeeNotes && (
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {/* SECCIÓN NOTAS MÉDICAS: Seguimiento colaborativo entre doctores */}
          <div class="glass-card rounded-2xl p-6">
            <div class="flex items-center justify-between mb-4 border-b border-white/40 pb-4">
              <h3 class="text-xl font-bold text-slate-800">Notas de Seguimiento</h3>
              <span class="text-[10px] bg-slate-100 text-slate-500 px-2 py-0.5 rounded font-bold uppercase tracking-widest">Informativas</span>
            </div>
            <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
              {
                allNotes.filter(n => n.isAlert === 0).length > 0 ? (
                  allNotes.filter(n => n.isAlert === 0).map((note) => (
                    <div class="p-4 bg-white/40 rounded-xl border border-white/60 relative group">
                      <div class="flex justify-between items-start mb-1">
                        <p class="text-[11px] font-bold text-teal-700 uppercase tracking-tighter">{note.author} ({note.authorRole})</p>
                        <p class="text-[10px] text-slate-400">{String(note.createdAt).split(' ')[0]}</p>
                      </div>
                      <p class="text-sm text-slate-700 italic">"{note.content}"</p>
                      {note.tags && (
                        <div class="mt-2 flex gap-1">
                          {String(note.tags).split(',').filter(t => t.trim()).map((tag: string) => (
                            <span class="text-[9px] bg-slate-200 text-slate-600 px-1.5 py-0.5 rounded-md font-bold uppercase">{tag.trim()}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  ))
                ) : (
                  <div class="text-sm text-slate-500 py-2 italic text-center">
                    No hay notas de seguimiento privadas para este alumno.
                  </div>
                )
              }
            </div>
          </div>

          {/* SECCIÓN HISTORIAL DE ALERTAS: Registro histórico de prioridades */}
          <div class="glass-card rounded-2xl p-6 border-rose-100">
            <div class="flex items-center justify-between mb-4 border-b border-white/40 pb-4">
              <div class="flex items-center gap-2">
                 <svg class="w-5 h-5 text-rose-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={ICONS.alert} />
                 <h3 class="text-xl font-bold text-slate-800">Historial de Alertas</h3>
              </div>
              <span class="text-[10px] bg-rose-50 text-rose-600 px-2 py-0.5 rounded font-bold uppercase tracking-widest">Clínicas</span>
            </div>
            <div class="space-y-4 max-h-[400px] overflow-y-auto pr-2 custom-scrollbar">
              {
                allNotes.filter(n => n.isAlert === 1).length > 0 ? (
                  allNotes.filter(n => n.isAlert === 1).map((note) => (
                    <div class={`p-4 rounded-xl border relative group ${note.status === 'active' ? 'bg-rose-50/50 border-rose-200' : 'bg-slate-50/50 border-slate-200 opacity-80'}`}>
                      <div class="flex justify-between items-start mb-1">
                        <p class="text-[11px] font-bold text-rose-800 uppercase tracking-tighter">{note.author} ({note.authorRole})</p>
                        <div class="flex gap-2 items-center">
                          {note.status === 'active' ? (
                            <span class="text-[8px] bg-rose-500 text-white px-1.5 py-0.5 rounded-full font-bold uppercase animate-pulse">Activa</span>
                          ) : (
                             <span class="text-[8px] bg-slate-200 text-slate-500 px-1.5 py-0.5 rounded-full font-bold uppercase">Quitada</span>
                          )}
                          <p class="text-[10px] text-slate-400">{String(note.createdAt).split(' ')[0]}</p>
                        </div>
                      </div>
                      <p class="text-sm text-slate-700 font-medium">"{note.content}"</p>
                      {note.tags && (
                        <div class="mt-2 flex gap-1">
                          {String(note.tags).split(',').filter(t => t.trim()).map((tag: string) => (
                            <span class="text-[9px] bg-rose-100 text-rose-600 px-1.5 py-0.5 rounded-md font-bold uppercase">{tag.trim()}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  ))
                ) : (
                  <div class="text-sm text-slate-500 py-2 italic text-center">
                    No se han registrado alertas clínicas para este alumno.
                  </div>
                )
              }
            </div>
          </div>
        </div>
      )
    }

    {/* SECCIÓN LESIONES: Oculta para nutriólogo */}
    {!isNutritionist && (
    <div class="glass-card rounded-2xl p-6">
      <div
        class="flex items-center justify-between mb-4 border-b border-white/40 pb-4"
      >
        <h3 class="text-xl font-bold text-slate-800">Lesiones</h3>
        {
          (isDoctorOrAdmin || isStudent || isFisioterapeuta) && (
            <a
              href={`/injuries/add?patientId=${patient.id}`}
              class="flex items-center gap-1 text-sm bg-teal-50 text-teal-700 px-3 py-1.5 rounded-lg border border-teal-200 font-semibold hover:bg-teal-500 hover:text-white transition-colors"
            >
              <svg
                class="w-4 h-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                set:html={ICONS.plus}
              />
              Reportar Lesión
            </a>
          )
        }
      </div>
      <div class="space-y-3">
        {
          injuries.length > 0 ? (
            injuries.map((inj) => (
              <div class="p-4 bg-rose-50/50 rounded-xl border border-rose-100 group">
                <div class="flex justify-between items-start mb-2">
                  <p class="font-bold text-rose-900 text-sm">
                    {inj.type} en {inj.zone}
                  </p>
                  {isDoctorOrAdmin ? (
                    <a
                      href={`/injuries/${inj.id}/edit`}
                      class="text-xs font-semibold text-rose-600 hover:text-rose-800 bg-white px-2 py-1 rounded shadow-sm border border-rose-100 flex items-center gap-1"
                    >
                      <svg
                        class="w-3 h-3"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={ICONS.edit}
                      />{" "}
                      Ver/Editar
                    </a>
                  ) : (
                    <a
                      href={`/injuries/${inj.id}`}
                      class="text-xs font-semibold text-rose-600 hover:text-rose-800 bg-white px-2 py-1 rounded shadow-sm border border-rose-100 flex items-center gap-1"
                    >
                      <svg
                        class="w-3 h-3"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        set:html={ICONS.eye}
                      />{" "}
                      Ver Detalles
                    </a>
                  )}
                </div>
                <div class="flex flex-wrap gap-2 text-[10px] font-bold uppercase tracking-wider">
                  {/* Badges de estado con colores dinámicos según severidad y recuperación */}
                  <span class="bg-rose-100 text-rose-700 px-2.5 py-1 rounded-md border border-rose-200">
                    {inj.severity}
                  </span>
                  <span class="bg-amber-100 text-amber-700 px-2.5 py-1 rounded-md border border-amber-200">
                    {inj.status}
                  </span>
                  <span class="bg-slate-100 text-slate-600 px-2.5 py-1 rounded-md border border-slate-200">
                    {inj.date}
                  </span>
                </div>
              </div>
            ))
          ) : (
            <div class="text-sm text-slate-500 py-2">
              No hay historial de lesiones.
            </div>
          )
        }
      </div>
    </div>
    )}

    {/* SECCIÓN NUTRICIÓN (Nutriólogo / Doctor) - Enlace rápido a perfil nutricional */}
    {isNutritionist && (
    <div class="glass-card rounded-2xl p-6 bg-gradient-to-br from-emerald-50/50 to-teal-50/50 border border-emerald-100">
      <div class="flex items-center justify-between mb-4 border-b border-emerald-100 pb-4"
      >
        <h3 class="text-xl font-bold text-slate-800">Nutrición</h3>
        <a
          href={`/nutrition/profiles/add?patientId=${patient.id}`}
          class="flex items-center gap-1 text-sm bg-emerald-500 text-white px-3 py-1.5 rounded-lg font-semibold hover:bg-emerald-600 transition-colors"
        >
          <svg
            class="w-4 h-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            set:html={ICONS.plus}
          />
          Crear Evaluación
        </a>
      </div>
      <p class="text-slate-600 text-sm mb-4">
        Ve al panel de nutrición para crear el historial dietético y recetar
        el plan de alimentación para {patient.firstName}.
      </p>
      <a
        href={`/nutrition/profiles`}
        class="w-full flex justify-center py-2.5 text-emerald-700 bg-emerald-100/50 border border-emerald-200 rounded-xl font-bold text-sm hover:bg-emerald-200 transition-colors"
      >
        Ir a Perfiles Nutricionales &rarr;
      </a>
    </div>
    )}

    {/* SECCIÓN NUTRICIÓN (Estudiante) - Enlace rápido a su Plan Nutricional Activo */}
    {isStudent && activePlanId && (
    <div class="glass-card rounded-2xl p-6 bg-gradient-to-br from-amber-50/50 to-orange-50/50 border border-amber-100">
      <div class="flex items-center justify-between mb-4 border-b border-amber-100 pb-4">
        <h3 class="text-xl font-bold text-slate-800">Tu Nutrición</h3>
      </div>
      <p class="text-slate-600 text-sm mb-4">
        Tienes un plan alimenticio activo configurado por tu nutriólogo. Revísalo aquí.
      </p>
      <a
        href={`/nutrition/plans/${activePlanId}`}
        class="w-full flex justify-center py-2.5 text-amber-800 bg-amber-100/50 border border-amber-200 rounded-xl font-bold text-sm hover:bg-amber-200 transition-colors"
      >
        Ver mi Plan Nutricional &rarr;
      </a>
    </div>
    )}
  </div>

    {/* SECCIÓN FISIOTERAPIA */}
    {canSeePhysio && (
    <div class="glass-card rounded-2xl p-6 bg-gradient-to-br from-violet-50/50 to-purple-50/50 border border-violet-100 mt-8">
      <div class="flex items-center justify-between mb-4 border-b border-violet-100 pb-4">
        <h3 class="text-xl font-bold text-slate-800">Fisioterapia</h3>
        {isFisioterapeuta && (
          <a
            href={`/physiotherapy/new?patientId=${patient.id}`}
            class="flex items-center gap-1 text-sm bg-violet-500 text-white px-3 py-1.5 rounded-lg font-semibold hover:bg-violet-600 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5v14"/></svg>
            Nuevo Plan
          </a>
        )}
      </div>
      {physioPlans.length === 0 ? (
        <p class="text-sm text-slate-500 italic">No hay planes de fisioterapia para este paciente.</p>
      ) : (
        <div class="space-y-3">
          {physioPlans.map((pp: any) => {
            const adh = Number(pp.totalSessions) > 0 ? Math.round((Number(pp.completedSessions) / Number(pp.totalSessions)) * 100) : 0;
            const stColor = pp.status === 'Activo' ? 'bg-emerald-50 text-emerald-700 border-emerald-200' : pp.status === 'Completado' ? 'bg-sky-50 text-sky-700 border-sky-200' : 'bg-slate-100 text-slate-500 border-slate-200';
            return (
              <a href={`/physiotherapy/${pp.planId}`} class="block p-4 bg-white/40 rounded-xl border border-white/60 hover:border-violet-200 hover:bg-violet-50/30 transition-colors group">
                <div class="flex justify-between items-start mb-2">
                  <div>
                    <p class="font-bold text-slate-800 text-sm group-hover:text-violet-700 transition-colors">{pp.physioName}</p>
                    {pp.injuryType && <p class="text-xs text-slate-400">{pp.injuryType} · {pp.bodyZone}</p>}
                  </div>
                  <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full border uppercase ${stColor}`}>{pp.status}</span>
                </div>
                <div class="flex justify-between text-xs text-slate-500">
                  <span>Inicio: {pp.startDate}</span>
                  <span class={adh >= 80 ? 'text-emerald-600 font-bold' : adh >= 50 ? 'text-amber-600 font-bold' : 'text-rose-600 font-bold'}>Adherencia: {adh}%</span>
                </div>
              </a>
            );
          })}
          {!isStudent && <a href={`/physiotherapy?q=${patient.firstName}`} class="block text-center text-xs text-violet-600 font-semibold hover:underline mt-1">Ver todos los planes →</a>}
        </div>
      )}
    </div>
    )}


  <div id="noteModal" class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 hidden flex items-center justify-center p-4">
    <div class="bg-white rounded-3xl shadow-2xl w-full max-w-lg overflow-hidden animate-in zoom-in-95 duration-200">
      <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
        <h3 class="font-bold text-xl text-slate-800">Nueva Nota / Alerta</h3>
        <button id="closeNoteModal" class="text-slate-400 hover:text-slate-600 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>
      <form method="POST" class="p-6 space-y-4">
        <input type="hidden" name="_action" value="addNote" />
        
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5 capitalize">Contenido de la nota</label>
          <textarea 
            name="content" 
            required 
            rows="4" 
            class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-3 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500 transition-all"
            placeholder="Introduce los detalles médicos o de seguimiento..."
          ></textarea>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-1.5">Etiquetas (opcional)</label>
            <input 
              type="text" 
              name="tags" 
              class="w-full bg-slate-50 border border-slate-200 rounded-xl px-4 py-2 text-slate-700 focus:outline-none focus:ring-2 focus:ring-teal-500"
              placeholder="Ej: Dieta, Crónico"
            />
          </div>
          <div class="flex items-center gap-3 pt-6">
            <input 
              type="checkbox" 
              name="isAlert" 
              id="isAlertCheck"
              class="w-5 h-5 text-rose-600 border-slate-300 rounded focus:ring-rose-500"
            />
            <label for="isAlertCheck" class="text-sm font-bold text-rose-700 cursor-pointer">Marcar como ALERTA</label>
          </div>
        </div>

        <div class="pt-4 flex gap-3">
           <button type="button" id="cancelNoteModal" class="flex-1 py-3 border border-slate-200 text-slate-500 font-bold rounded-xl hover:bg-slate-50 transition-colors">Cancelar</button>
           <button type="submit" class="flex-1 py-3 bg-gradient-to-r from-teal-500 to-emerald-600 text-white font-bold rounded-xl shadow-lg hover:shadow-teal-500/20 transition-all active:scale-[0.98]">Guardar Nota</button>
        </div>
      </form>
    </div>
  </div>

</Layout>

<script>
  const openBtn = document.getElementById('openNoteModal');
  const closeBtn = document.getElementById('closeNoteModal');
  const cancelBtn = document.getElementById('cancelNoteModal');
  const modal = document.getElementById('noteModal');

  openBtn?.addEventListener('click', () => {
    modal?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  });

  const closeModal = () => {
    modal?.classList.add('hidden');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);
  cancelBtn?.addEventListener('click', closeModal);

  // Cerrar al hacer clic fuera del modal
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  // Abrir automáticamente si el parámetro openNotes=true está presente
  const urlParams = new URLSearchParams(window.location.search);
  if (urlParams.get('openNotes') === 'true' && modal) {
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }
</script>
