---
import Layout from '../../layouts/Layout.astro';
import PatientForm from '../../components/Patient/PatientForm.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.ADMINISTRADOR])) {
  return Astro.redirect('/403');
}

// Obtener lista de coaches para el dropdown
const coachesRes = await db.execute({
  sql: `SELECT userId, firstName, lastName FROM Users WHERE roleId = ?`,
  args: [ROLES.ENTRENADOR]
});
const coaches = coachesRes.rows;

let error = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const firstName = data.get('firstName') as string;
    const lastName = data.get('lastName') as string;
    const matricula = data.get('matricula') as string;
    const gender = data.get('gender') as string;
    const dateOfBirth = data.get('dateOfBirth') as string;
    const bloodType = data.get('bloodType') as string;
    const weight = data.get('weight') ? Number(data.get('weight')) : null;
    const height = data.get('height') ? Number(data.get('height')) : null;
    const allergies = data.get('allergies') as string;
    const isAthlete = data.get('isAthlete') === '1' ? 1 : 0;
    const schoolLevel = data.get('schoolLevel') as string;
    const coachId = data.get('coachId') ? Number(data.get('coachId')) : null;

    // Transaction to ensure both User and Patient are created
    const batchResult = await db.batch([
      {
        sql: `INSERT INTO Users (firstName, lastName, matricula, roleId) VALUES (?, ?, ?, ?)`,
        args: [firstName, lastName, matricula || null, ROLES.ESTUDIANTE]
      },
      {
        sql: `INSERT INTO Patients (patientId, dateOfBirth, gender, bloodType, allergies, weight, height, isAthlete, schoolLevel)
              VALUES (last_insert_rowid(), ?, ?, ?, ?, ?, ?, ?, ?)`,
        args: [dateOfBirth, gender, bloodType, allergies, weight, height, isAthlete, schoolLevel]
      }
    ], "write");

    // Obtener el ID del paciente recién creado
    const patientIdResult = await db.execute({
      sql: `SELECT last_insert_rowid() as patientId`
    });
    const newPatientId = Number(patientIdResult.rows[0].patientId);

    // Si es atleta y se seleccionó un coach, crear la relación
    if (isAthlete === 1 && coachId) {
      await db.execute({
        sql: `INSERT INTO Coach_Athlete (coachId, patientId) VALUES (?, ?)`,
        args: [coachId, newPatientId]
      });
    }

    return Astro.redirect('/patients');
  } catch (e) {
    if (e instanceof Error) {
      error = e.message;
      if (error.includes('UNIQUE constraint failed: Users.matricula')) {
        error = 'Ya existe un usuario con esa matrícula.';
      }
      console.error('Error creating patient:', error);
    }
  }
}
---

<Layout title="Nuevo Paciente">
  <div class="mb-8">
    <div class="flex items-center gap-3 text-sm font-semibold text-slate-500 mb-2">
      <a href="/patients" class="hover:text-teal-600 transition-colors">Pacientes</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-teal-700">Nuevo Registro</span>
    </div>
    <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Agregar Paciente</h1>
  </div>

  {error && (
    <div class="bg-rose-50 border border-rose-200 text-rose-600 px-4 py-3 rounded-xl text-sm mb-6 animate-fade-in shadow-sm flex items-center gap-2 max-w-4xl">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="flex-shrink-0"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      {error}
    </div>
  )}

  <div class="max-w-4xl">
    <PatientForm coaches={coaches} />
  </div>
</Layout>
