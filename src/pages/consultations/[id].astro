---
import Layout from '../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.DOCTOR, ROLES.JEFE_MEDICO, ROLES.ADMINISTRADOR, ROLES.ESTUDIANTE, ROLES.NUTRIOLOGO])) {
  return Astro.redirect('/403');
}

const { id } = Astro.params;
if (!id) return Astro.redirect('/404');

const isDoctorOrAdmin: boolean = user?.roleId === ROLES.DOCTOR || user?.roleId === ROLES.ADMINISTRADOR || user?.roleId === ROLES.JEFE_MEDICO;

// 1. Obtener datos de la consulta + paciente + cita
const consRes = await db.execute({
  sql: `SELECT c.consultationId, c.diagnosis, c.symptoms, c.consultationDate,
               c.appointmentId,
               u.firstName || ' ' || u.lastName as patient,
               a.patientId,
               ud.firstName || ' ' || ud.lastName as doctor,
               a.dateTime as aptDateTime, a.status as aptStatus,
               p.dateOfBirth, p.bloodType, p.allergies
        FROM Consultations c
        JOIN Appointments a ON c.appointmentId = a.appointmentId
        JOIN Patients p ON a.patientId = p.patientId
        JOIN Users u ON p.patientId = u.userId
        JOIN Users ud ON a.specialistId = ud.userId
        WHERE c.consultationId = ?`,
  args: [String(id)]
});

if (consRes.rows.length === 0) {
  return Astro.redirect('/404');
}

const cons = consRes.rows[0];

// Security: Students can only view their own consultations
if (user?.roleId === ROLES.ESTUDIANTE && String(user.userId) !== String(cons.patientId)) {
  return Astro.redirect('/403');
}

// Security: Doctors/Nutritionists/Coaches can only view their assigned patients
let requiredRoleType = "";
if (user?.roleId === ROLES.DOCTOR) requiredRoleType = "Doctor";
else if (user?.roleId === ROLES.NUTRIOLOGO) requiredRoleType = "Nutritionist";
else if (user?.roleId === ROLES.ENTRENADOR) requiredRoleType = "Coach";

if (requiredRoleType && user) {
  const accessCheck = await db.execute({
    sql: `SELECT 1 FROM User_Patient WHERE userId = ? AND patientId = ? AND roleType = ?`,
    args: [user.userId, cons.patientId, requiredRoleType]
  });
  if (accessCheck.rows.length === 0) {
    return Astro.redirect("/403");
  }
}

// 2. Obtener recetas de esta consulta
const presRes = await db.execute({
  sql: `SELECT pr.prescriptionId, pr.dosage, pr.frequency, pr.duration,
               m.brandName, m.activeIngredient, m.presentation, m.medicationId
        FROM Prescriptions pr
        JOIN Medications m ON pr.medicationId = m.medicationId
        WHERE pr.consultationId = ?`,
  args: [String(id)]
});
const prescriptions = presRes.rows;

// 3. Obtener archivos clínicos
const filesRes = await db.execute({
  sql: `SELECT fileId, fileType, fileUrl FROM ClinicalFiles WHERE consultationId = ?`,
  args: [String(id)]
});
const clinicalFiles = filesRes.rows;

// 4. Obtener medicamentos para el formulario
const medsRes = await db.execute(`SELECT medicationId, brandName, activeIngredient, presentation FROM Medications WHERE currentStock > 0`);
const medications = medsRes.rows;

// 5. Manejar POST
if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('_action') as string;

  if (!isDoctorOrAdmin) return Astro.redirect('/403');

  if (action === 'update') {
    const symptoms = data.get('symptoms') as string;
    const diagnosis = data.get('diagnosis') as string;
    await db.execute({
      sql: `UPDATE Consultations SET symptoms = ?, diagnosis = ? WHERE consultationId = ?`,
      args: [symptoms, diagnosis, String(id)]
    });
  }

  if (action === 'add_prescription') {
    const medicationId = data.get('medicationId') as string;
    const dosage = data.get('dosage') as string;
    const frequency = data.get('frequency') as string;
    const duration = data.get('duration') as string;
    await db.execute({
      sql: `INSERT INTO Prescriptions (consultationId, medicationId, dosage, frequency, duration) VALUES (?, ?, ?, ?, ?)`,
      args: [String(id), Number(medicationId), dosage, frequency, duration]
    });
  }

  if (action === 'delete_prescription') {
    const prescriptionId = data.get('prescriptionId') as string;
    await db.execute({
      sql: `DELETE FROM Prescriptions WHERE prescriptionId = ?`,
      args: [prescriptionId]
    });
  }

  if (action === 'add_file') {
    const fileType = data.get('fileType') as string;
    const fileUrl = data.get('fileUrl') as string;
    await db.execute({
      sql: `INSERT INTO ClinicalFiles (consultationId, fileType, fileUrl) VALUES (?, ?, ?)`,
      args: [String(id), fileType, fileUrl]
    });
  }

  if (action === 'delete_file') {
    const fileId = data.get('fileId') as string;
    await db.execute({
      sql: `DELETE FROM ClinicalFiles WHERE fileId = ?`,
      args: [fileId]
    });
  }

  return Astro.redirect(`/consultations/${id}`);
}

const age = cons.dateOfBirth ? Math.abs(new Date(Date.now() - new Date(cons.dateOfBirth as string).getTime()).getUTCFullYear() - 1970) : 'N/A';
---

<Layout title={`Consulta: ${cons.patient}`}>
  <!-- Header con Botón de PDF -->
  <div class="mb-8">
    <div class="flex items-center gap-3 text-sm font-semibold text-slate-500 mb-2">
      <a href={`/patients/${cons.patientId}`} class="hover:text-teal-600 transition-colors">Expediente del Paciente</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-teal-700">Consulta #{String(id).padStart(4, '0')}</span>
    </div>

    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Registro de Consulta</h1>
        <p class="text-slate-500 mt-1">
          Paciente: <span class="font-semibold text-slate-700">{cons.patient}</span> · 
          Atendido por <span class="font-semibold text-slate-700">Dr. {cons.doctor}</span>
        </p>
      </div>
      <div class="flex items-center gap-3">
        <button id="downloadPdf" class="px-5 py-2.5 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl shadow-sm hover:bg-slate-50 transition-all flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-rose-500"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          Descargar Receta PDF
        </button>
        <span class="bg-teal-50 border border-teal-200 text-teal-700 text-xs font-bold px-4 py-2 rounded-xl uppercase tracking-widest hidden md:inline-block">
          {String(cons.consultationDate).split('T')[0]}
        </span>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 xl:grid-cols-3 gap-8">

    <!-- Left: Content Panels -->
    <div class="xl:col-span-2 space-y-6">

      <!-- 1. Diagnóstico y Síntomas (Editable) -->
      <div class="glass-card rounded-2xl p-6 border-l-4 border-l-teal-500">
        {isDoctorOrAdmin ? (
          <form method="POST">
            <input type="hidden" name="_action" value="update"/>
            <div class="flex items-center justify-between mb-5 border-b border-slate-100 pb-3">
              <h3 class="text-lg font-bold text-slate-800">Diagnóstico y Síntomas</h3>
              <button type="submit" class="text-xs bg-teal-50 text-teal-700 font-bold px-3 py-1.5 rounded-lg border border-teal-100 hover:bg-teal-100 transition-colors">Guardar Cambios</button>
            </div>
            <div class="space-y-5">
              <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-1">Síntomas / Motivo de Consulta</label>
                <textarea name="symptoms" rows="3" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500">{cons.symptoms}</textarea>
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-400 uppercase tracking-wider mb-1.5 ml-1">Diagnóstico Médico</label>
                <textarea name="diagnosis" rows="3" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 font-medium">{cons.diagnosis}</textarea>
              </div>
            </div>
          </form>
        ) : (
          <div>
            <h3 class="text-lg font-bold text-slate-800 mb-5 border-b border-slate-100 pb-3">Resumen Médico</h3>
            <div class="space-y-5">
              <div>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mb-1">Síntomas</p>
                <p class="text-slate-700 leading-relaxed font-medium">{cons.symptoms || 'Sin registrar'}</p>
              </div>
              <div>
                <p class="text-xs text-slate-400 font-bold uppercase tracking-widest mb-1">Diagnóstico</p>
                <p class="text-slate-800 font-bold leading-relaxed">{cons.diagnosis || 'Sin registrar'}</p>
              </div>
            </div>
          </div>
        )}
      </div>

      <!-- 2. Recetas (Integrado) -->
      <div class="glass-card rounded-2xl p-6 border-l-4 border-l-indigo-500">
        <div class="flex items-center justify-between mb-6 border-b border-slate-100 pb-3">
          <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            Prescripciones y Medicamentos
          </h3>
          <button id="togglePrescriptionForm" class="text-xs bg-indigo-50 text-indigo-700 font-bold px-3 py-1.5 rounded-lg border border-indigo-100 hover:bg-indigo-100 transition-colors">
            + Añadir Medicamento
          </button>
        </div>

        <!-- Formulario Inline de Receta -->
        <div id="prescriptionForm" class="hidden mb-8 p-5 bg-indigo-50/50 rounded-2xl border border-indigo-100 animate-slide-down">
          <form method="POST" class="space-y-4">
            <input type="hidden" name="_action" value="add_prescription"/>
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 ml-1">Seleccionar Medicamento (Inventario)</label>
              <select name="medicationId" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" required>
                <option value="">Buscar en farmacia...</option>
                {medications.map(m => (
                  <option value={String(m.medicationId)}>{m.brandName} ({m.activeIngredient}) - {m.presentation}</option>
                ))}
              </select>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
              <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 ml-1">Dosis</label>
                <input type="text" name="dosage" placeholder="1 tableta" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" required />
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 ml-1">Frecuencia</label>
                <input type="text" name="frequency" placeholder="Cada 8 horas" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" required />
              </div>
              <div>
                <label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 ml-1">Duración</label>
                <input type="text" name="duration" placeholder="7 días" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-indigo-500 outline-none" required />
              </div>
            </div>
            <div class="flex justify-end gap-2 pt-2">
              <button type="button" id="cancelPrescription" class="px-4 py-2 text-sm font-semibold text-slate-500 hover:text-slate-700">Cancelar</button>
              <button type="submit" class="px-5 py-2 bg-indigo-600 text-white font-bold text-sm rounded-lg shadow-sm hover:bg-indigo-700 transition-colors">Guardar en Receta</button>
            </div>
          </form>
        </div>

        <div class="space-y-4">
          {prescriptions.length === 0 ? (
            <div class="text-center py-6 bg-slate-50/50 rounded-xl border border-dashed border-slate-200 text-slate-400">
               <p class="text-sm">Sin medicamentos registrados aún.</p>
            </div>
          ) : (
            prescriptions.map((pr: any) => (
              <div class="flex items-center justify-between p-4 bg-white/50 rounded-xl border border-slate-100 group">
                <div class="flex items-center gap-4">
                  <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-lg flex items-center justify-center font-bold">Px</div>
                  <div>
                    <p class="font-bold text-slate-800">{pr.brandName}</p>
                    <p class="text-xs text-slate-500">{pr.dosage} • {pr.frequency} • {pr.duration}</p>
                  </div>
                </div>
                {isDoctorOrAdmin && (
                  <form method="POST" onsubmit="return confirm('¿Eliminar de la receta?')">
                    <input type="hidden" name="_action" value="delete_prescription"/>
                    <input type="hidden" name="prescriptionId" value={pr.prescriptionId}/>
                    <button type="submit" class="w-8 h-8 flex items-center justify-center opacity-0 group-hover:opacity-100 text-slate-300 hover:text-rose-500 transition-all">
                      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
                    </button>
                  </form>
                )}
              </div>
            ))
          )}
        </div>
      </div>

      <!-- 3. Archivos y Adjuntos (Nuevo) -->
      <div class="glass-card rounded-2xl p-6 border-l-4 border-l-amber-500">
        <div class="flex items-center justify-between mb-6 border-b border-slate-100 pb-3">
          <h3 class="text-lg font-bold text-slate-800 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-amber-500"><path d="M15.5 2H8.6c-.4 0-.8.2-1.1.5-.3.3-.5.7-.5 1.1v12.8c0 .4.2.8.5 1.1.3.3.7.5 1.1.5h9.8c.4 0 .8-.2 1.1-.5.3-.3.5-.7.5-1.1V6.5L15.5 2z"/><path d="M15 2v5h5"/><path d="M11 9H8"/><path d="M11 13H8"/><path d="M8 17h10"/></svg>
            Adjuntos y Archivos Clínicos
          </h3>
          <button id="toggleFileForm" class="text-xs bg-amber-50 text-amber-700 font-bold px-3 py-1.5 rounded-lg border border-amber-100 hover:bg-amber-100 transition-colors">
            + Adjuntar Archivo
          </button>
        </div>

        <div id="fileForm" class="hidden mb-8 p-5 bg-amber-50/30 rounded-2xl border border-amber-100 border-dashed">
          <form method="POST" class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <input type="hidden" name="_action" value="add_file"/>
            <div class="md:col-span-2 text-xs text-amber-700 mb-2 font-medium bg-amber-100/50 p-2 rounded">
              Añade el enlace de archivos externos (Drive, Cloudinary, etc) para vincularlos a este expediente.
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 ml-1">Nombre/Tipo de Archivo</label>
              <input type="text" name="fileType" placeholder="Ej. Radiografía Tórax" class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-amber-500 outline-none" required />
            </div>
            <div>
              <label class="block text-xs font-bold text-slate-500 uppercase mb-1.5 ml-1">URL / Enlace del Archivo</label>
              <input type="url" name="fileUrl" placeholder="https://..." class="w-full bg-white border border-slate-200 rounded-xl px-4 py-2.5 text-sm focus:ring-2 focus:ring-amber-500 outline-none" required />
            </div>
            <div class="md:col-span-2 flex justify-end gap-2 pt-2">
              <button type="button" id="cancelFile" class="px-4 py-2 text-sm font-semibold text-slate-500 hover:text-slate-700">Cancelar</button>
              <button type="submit" class="px-5 py-2 bg-amber-600 text-white font-bold text-sm rounded-lg shadow-sm hover:bg-amber-700 transition-colors">Adjuntar</button>
            </div>
          </form>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {clinicalFiles.length === 0 ? (
            <div class="md:col-span-2 text-center py-6 text-slate-400">
               <p class="text-sm">Sin archivos adjuntos.</p>
            </div>
          ) : (
            clinicalFiles.map((file: any) => (
              <div class="p-4 bg-white/50 rounded-xl border border-slate-100 flex items-center justify-between group">
                <a href={file.fileUrl} target="_blank" class="flex items-center gap-3 flex-1">
                  <div class="w-9 h-9 bg-slate-100 text-slate-500 rounded-lg flex items-center justify-center">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                  </div>
                  <div>
                    <p class="text-sm font-bold text-slate-800">{file.fileType}</p>
                    <p class="text-[10px] text-teal-600 font-bold uppercase truncate max-w-[150px]">Link Externo</p>
                  </div>
                </a>
                {isDoctorOrAdmin && (
                  <form method="POST">
                    <input type="hidden" name="_action" value="delete_file"/>
                    <input type="hidden" name="fileId" value={file.fileId}/>
                    <button type="submit" class="text-slate-200 hover:text-rose-500 transition-colors">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                    </button>
                  </form>
                )}
              </div>
            ))
          )}
        </div>
      </div>
    </div>

    <!-- Sidebar: Patient Context -->
    <div class="xl:col-span-1">
      <div class="glass-strong rounded-2xl p-6 sticky top-24 border border-slate-200/60 shadow-xl space-y-6">
        <div>
          <h3 class="font-bold text-slate-800 text-lg border-b border-slate-100 pb-3 mb-4">Paciente</h3>
          <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-gradient-to-br from-teal-500 to-emerald-500 text-white rounded-2xl flex items-center justify-center font-bold text-xl shadow-lg shadow-teal-100">
              {String(cons.patient || "").split(' ').filter(n => n.trim()).map((n: string) => n[0]).slice(0, 2).join('')}
            </div>
            <div>
              <p class="font-bold text-slate-800 text-lg">{cons.patient}</p>
              <p class="text-sm text-slate-500">{age} años • {cons.bloodType}</p>
            </div>
          </div>
        </div>

        <div class="space-y-4">
          <div class="p-4 bg-rose-50/50 border border-rose-100 rounded-xl">
             <p class="text-[10px] uppercase font-bold text-rose-400 tracking-widest mb-1">Alergias Detectadas</p>
             <p class="text-sm font-bold text-rose-700">{cons.allergies || 'Ninguna registrada'}</p>
          </div>

          <div class="space-y-2 text-sm">
            <div class="flex justify-between py-2 border-b border-slate-100">
              <span class="text-slate-500 font-medium">Médico</span>
              <span class="font-bold text-slate-800">Dr. {cons.doctor}</span>
            </div>
            <div class="flex justify-between py-2 border-b border-slate-100">
              <span class="text-slate-500 font-medium">Fecha</span>
              <span class="font-bold text-slate-800">{String(cons.consultationDate).split('T')[0]}</span>
            </div>
          </div>
        </div>

        <div class="pt-4 space-y-3">
          <a href={`/patients/${cons.patientId}`} class="w-full flex items-center justify-center gap-2 px-4 py-3 bg-white border border-slate-200 text-slate-700 font-bold rounded-xl hover:bg-slate-50 transition-all shadow-sm">
            Ver Expediente Médico
          </a>
        </div>
      </div>
    </div>
  </div>
        <div 
          id="pdfData" 
          data-cons={JSON.stringify(cons)} 
          data-pres={JSON.stringify(prescriptions)} 
          data-id={id}
          class="hidden"
        ></div>

        <script is:inline>
          function setupToggles() {
            const btnPrescription = document.getElementById('togglePrescriptionForm');
            const btnCancelPrescription = document.getElementById('cancelPrescription');
            const formPrescription = document.getElementById('prescriptionForm');

            btnPrescription?.addEventListener('click', () => formPrescription?.classList.toggle('hidden'));
            btnCancelPrescription?.addEventListener('click', () => formPrescription?.classList.add('hidden'));

            const btnFile = document.getElementById('toggleFileForm');
            const btnCancelFile = document.getElementById('cancelFile');
            const formFile = document.getElementById('fileForm');

            btnFile?.addEventListener('click', () => formFile?.classList.toggle('hidden'));
            btnCancelFile?.addEventListener('click', () => formFile?.classList.add('hidden'));
          }
          // Initialize immediately
          setupToggles();
          // Also handle view transitions if enabled
          document.addEventListener('astro:after-swap', setupToggles);
        </script>

        <script>
          import { jsPDF } from 'jspdf';
  document.getElementById('downloadPdf')?.addEventListener('click', () => {
    const dataContainer = document.getElementById('pdfData');
    if (!dataContainer) return;

    const cons = JSON.parse(dataContainer.getAttribute('data-cons') || '{}');
    const prescriptions = JSON.parse(dataContainer.getAttribute('data-pres') || '[]');
    const id = dataContainer.getAttribute('data-id');

    const doc = new jsPDF();
    
    // Configuración de datos
    const patientName = cons.patient;
    const doctorName = `Dr. ${cons.doctor}`;
    const date = String(cons.consultationDate).split('T')[0];
    const diagnosis = (cons.diagnosis || '').replace(/\n/g, ' ');
    const symptoms = (cons.symptoms || '').replace(/\n/g, ' ');
    
    // Header Minimalista
    doc.setFontSize(22);
    doc.setTextColor(13, 148, 136); // Teal 600
    doc.text("MedApp - Receta Médica", 20, 30);
    
    doc.setDrawColor(200, 200, 200);
    doc.line(20, 35, 190, 35);
    
    // Info General
    doc.setFontSize(10);
    doc.setTextColor(100, 100, 100);
    doc.text(`Paciente: ${patientName}`, 20, 45);
    doc.text(`Médico: ${doctorName}`, 120, 45);
    doc.text(`Fecha: ${date}`, 20, 50);
    doc.text(`ID Consulta: #${String(id).padStart(4, '0')}`, 120, 50);

    // Diagnóstico
    doc.setFontSize(12);
    doc.setTextColor(50, 50, 50);
    doc.setFont("helvetica", "bold");
    doc.text("Motivo de Consulta y Síntomas:", 20, 65);
    doc.setFont("helvetica", "normal");
    doc.setFontSize(10);
    doc.text(doc.splitTextToSize(symptoms, 170), 20, 72);

    doc.setFontSize(12);
    doc.setFont("helvetica", "bold");
    doc.text("Diagnóstico:", 20, 95);
    doc.setFont("helvetica", "normal");
    doc.setFontSize(10);
    doc.text(doc.splitTextToSize(diagnosis, 170), 20, 102);

    // Tratamiento / Receta
    doc.line(20, 125, 190, 125);
    doc.setFontSize(14);
    doc.setFont("helvetica", "bold");
    doc.setTextColor(79, 70, 229); // Indigo 600
    doc.text("Tratamiento Prescrito", 20, 135);

    doc.setFontSize(10);
    doc.setTextColor(0, 0, 0);
    
    let y = 145;
    prescriptions.forEach((pr: any, i: number) => {
        if (y > 270) {
          doc.addPage();
          y = 20;
        }
        doc.setFont("helvetica", "bold");
        doc.text(`${i+1}. ${pr.brandName}`, 25, y);
        doc.setFont("helvetica", "normal");
        doc.text(`    Dosis: ${pr.dosage} | Frec: ${pr.frequency} | Duración: ${pr.duration}`, 25, y + 5);
        y += 15;
    });

    if (prescriptions.length === 0) {
        doc.text("No se registraron medicamentos en esta consulta.", 25, y);
    }

    // Firma
    doc.line(70, 260, 140, 260);
    doc.setFontSize(9);
    doc.text(`Firma del Médico: ${doctorName}`, 105, 265, { align: 'center' });

    doc.save(`Receta_${patientName.replace(/ /g, '_')}_${date}.pdf`);
  });
</script>
</Layout>

<style>
  .animate-slide-down {
    animation: slideDown 0.3s ease-out forwards;
  }
  @keyframes slideDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
