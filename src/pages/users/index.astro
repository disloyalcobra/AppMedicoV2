---
import Layout from '../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.ADMINISTRADOR, ROLES.JEFE_MEDICO, ROLES.DOCTOR])) {
  return Astro.redirect('/403');
}

const isDoctor = user?.roleId === ROLES.DOCTOR;

// --- ACCIONES POST ---
if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('_action');
  const targetUserId = formData.get('userId') as string;

  if (action === 'clearPassword') {
    // 1. Validar que el usuario a resetear existe
    const targetRes = await db.execute({
      sql: `SELECT roleId FROM Users WHERE userId = ?`,
      args: [targetUserId]
    });

    if (targetRes.rows.length > 0) {
      const targetRole = Number(targetRes.rows[0].roleId);
      
      // 2. Regla de negocio: Los doctores solo resetean a pacientes (Estudiantes) o Staff
      // Evitar que reseteen a Admins o Jefes Médicos
      const canReset = !isDoctor || (targetRole !== ROLES.ADMINISTRADOR && targetRole !== ROLES.JEFE_MEDICO);

      if (canReset) {
        await db.execute({
          sql: `UPDATE Users SET password = NULL WHERE userId = ?`,
          args: [targetUserId]
        });
        return Astro.redirect('/users?success=cleared');
      }
    }
  }
}

const success = Astro.url.searchParams.get('success');

// Map Roles
const roleNames: Record<number, string> = {
    1: 'Administrador',
    2: 'Jefe Médico',
    3: 'Doctor',
    4: 'Nutriólogo',
    5: 'Estudiante',
    6: 'Staff (Farmacia/Recepción)',
    7: 'Entrenador',
    8: 'Fisioterapeuta'
};

// Búsqueda
const q = Astro.url.searchParams.get('q')?.trim() || '';

let sqlQuery = `
    SELECT userId, firstName, lastName, email, roleId 
    FROM Users 
`;
let args: any[] = [];

if (q) {
  sqlQuery += ` WHERE firstName LIKE ? OR lastName LIKE ? OR email LIKE ?`;
  args.push(`%${q}%`, `%${q}%`, `%${q}%`);
}

sqlQuery += ` ORDER BY roleId ASC, firstName ASC`;

const usersRes = await db.execute({
    sql: sqlQuery,
    args: args
});
const usersList = usersRes.rows;

---

<Layout title="Gestión de Usuarios">
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center mb-8 gap-4">
    <div>
      <h1 class="text-3xl font-bold text-slate-800 tracking-tight">Directorio del Personal</h1>
      <p class="text-slate-500 mt-1">Gestión global de accesos y roles (Doctores, Entrenadores, Staff)</p>
      
      {success === 'cleared' && (
        <div class="mt-4 p-3 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-xl text-xs font-bold flex items-center gap-2 animate-in fade-in slide-in-from-top-2">
           <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/><path d="m9 12 2 2 4-4"/></svg>
           CONTRASEÑA ELIMINADA. El usuario ya puede activar su cuenta desde el login.
        </div>
      )}
    </div>
    
    <div class="flex gap-3">
        {!isDoctor && (
          <a href="/users/add" class="bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-medium py-2.5 px-4 rounded-xl shadow-md hover:shadow-lg transition-all flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              Nuevo Usuario
          </a>
        )}
    </div>
  </div>

  <div class="glass-card rounded-2xl overflow-hidden border border-white/60">
    <!-- Filters / Search -->
    <div class="p-4 border-b border-slate-200/60 bg-white/30">
      <form method="GET" class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <div class="relative flex-1 max-w-md w-full">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-2.5 text-slate-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <input type="text" name="q" value={q} placeholder="Buscar por nombre o correo..." class="w-full bg-white/50 border border-slate-200/60 rounded-xl pl-10 pr-4 py-2 text-slate-800 text-sm focus:outline-none focus:ring-2 focus:ring-teal-500" />
        </div>
        <div class="flex items-center gap-4">
            <button type="submit" class="px-4 py-2 bg-gradient-to-r from-teal-500 to-emerald-500 text-white text-sm font-medium rounded-xl shadow-sm hover:shadow-md transition-all">Buscar</button>
            {q && <a href="/users" class="px-4 py-2 border border-slate-200 text-slate-600 text-sm font-medium rounded-xl hover:bg-slate-50 transition-colors">Limpiar</a>}
        </div>
      </form>
    </div>

    <!-- Table -->
    <div class="overflow-x-auto">
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-slate-50/50 border-b border-slate-200/60">
            <th class="p-4 text-xs tracking-widest text-slate-500 uppercase font-bold w-16 text-center">ID</th>
            <th class="p-4 text-xs tracking-widest text-slate-500 uppercase font-bold">Usuario</th>
            <th class="p-4 text-xs tracking-widest text-slate-500 uppercase font-bold">Rol Sistema</th>
            <th class="p-4 text-xs tracking-widest text-slate-500 uppercase font-bold text-right">Acciones</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100/60">
          {usersList.map((u: any) => (
            <tr class="hover:bg-white/40 transition-colors">
              <td class="p-4 text-center">
                <span class="text-slate-400 font-bold text-sm">#{u.userId}</span>
              </td>
              <td class="p-4">
                <div class="flex items-center gap-3">
                  <div class="w-10 h-10 rounded-full flex items-center justify-center border shadow-sm bg-teal-50 text-teal-700 font-bold border-teal-200">
                     {String(u.firstName)[0]}{String(u.lastName)[0]}
                  </div>
                  <div>
                    <p class="font-bold text-slate-800">{u.firstName} {u.lastName}</p>
                    <p class="text-xs text-slate-500">{u.email}</p>
                  </div>
                </div>
              </td>
              <td class="p-4">
                <span class={`px-2.5 py-1 rounded-lg text-xs font-bold uppercase tracking-widest border ${
                    u.roleId === ROLES.DOCTOR ? 'bg-indigo-50 text-indigo-700 border-indigo-200' :
                    u.roleId === ROLES.NUTRIOLOGO ? 'bg-amber-50 text-amber-700 border-amber-200' :
                    u.roleId === ROLES.ESTUDIANTE ? 'bg-slate-100 text-slate-600 border-slate-200' :
                    u.roleId === ROLES.ENTRENADOR ? 'bg-orange-50 text-orange-700 border-orange-200' :
                    u.roleId === ROLES.FISIOTERAPEUTA ? 'bg-violet-50 text-violet-700 border-violet-200' :
                    'bg-sky-50 text-sky-700 border-sky-200'
                }`}>
                    {roleNames[u.roleId as number] || 'Desconocido'}
                </span>
              </td>
              <td class="p-4 text-right">
                 {u.userId !== user?.userId && (
                    <div class="flex items-center justify-end gap-2">
                        {/* Botón Reiniciar Contraseña (Solo para roles permitidos) */}
                        {(!isDoctor || (u.roleId !== ROLES.ADMINISTRADOR && u.roleId !== ROLES.JEFE_MEDICO)) && (
                          <form method="POST" class="inline" onsubmit="return confirm('¿Estás seguro de eliminar la contraseña de este usuario? Tendrá que activarla de nuevo desde el login.');">
                            <input type="hidden" name="_action" value="clearPassword" />
                            <input type="hidden" name="userId" value={u.userId} />
                            <button type="submit" class="w-8 h-8 rounded-lg bg-rose-50 border border-rose-100 flex items-center justify-center text-rose-400 hover:text-rose-600 hover:border-rose-200 transition-colors shadow-sm" title="Eliminar Contraseña">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><path d="m15 15-6 6"/><path d="m9 15 6 6"/></svg>
                            </button>
                          </form>
                        )}

                        {!isDoctor && (
                          <a href={`/users/${u.userId}`} class="w-8 h-8 rounded-lg bg-white border border-slate-200 flex items-center justify-center text-slate-400 hover:text-teal-600 hover:border-teal-300 transition-colors shadow-sm" title="Editar">
                              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
                          </a>
                        )}
                    </div>
                 )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</Layout>
