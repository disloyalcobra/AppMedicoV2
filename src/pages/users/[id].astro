---
import Layout from '../../layouts/Layout.astro';
import { ROLES, checkRole } from '../../functions/checkRole';
import { db } from '../../turso';

const user = Astro.locals.user;
if (!checkRole(user, [ROLES.ADMINISTRADOR, ROLES.JEFE_MEDICO])) {
  return Astro.redirect('/403');
}

const { id } = Astro.params;

const userRes = await db.execute({
  sql: `SELECT u.userId, u.firstName, u.lastName, u.email, u.roleId, r.roleName
        FROM Users u JOIN Roles r ON u.roleId = r.roleId WHERE u.userId = ?`,
  args: [String(id)]
});

if (userRes.rows.length === 0) {
  return Astro.redirect('/404');
}

const u = userRes.rows[0];

const rolesRes = await db.execute(`SELECT roleId, roleName FROM Roles ORDER BY roleId`);
const roles = rolesRes.rows;



if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const firstName = data.get('firstName') as string;
  const lastName  = data.get('lastName') as string;
  const email     = data.get('email') as string;
  const roleId    = data.get('roleId') as string;

  await db.execute({
    sql: `UPDATE Users SET firstName = ?, lastName = ?, email = ?, roleId = ? WHERE userId = ?`,
    args: [firstName, lastName, email, roleId, String(id)]
  });

  return Astro.redirect('/users');
}
---

<Layout title={`Editar Usuario: ${u.firstName} ${u.lastName}`}>
  <div class="mb-8">
    <div class="flex items-center gap-3 text-sm font-semibold text-slate-500 mb-2">
      <a href="/users" class="hover:text-teal-600 transition-colors">Directorio del Personal</a>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      <span class="text-teal-700">Editar Usuario</span>
    </div>

    <div class="flex items-center gap-4">
      <div class="w-14 h-14 rounded-full bg-teal-50 text-teal-700 border border-teal-200 flex items-center justify-center font-bold text-xl shadow-sm">
        {String(u.firstName)[0]}{String(u.lastName)[0]}
      </div>
      <div>
        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">{u.firstName} {u.lastName}</h1>
        <p class="text-slate-500 text-sm mt-1">ID #{u.userId} — {u.roleName}</p>
      </div>
    </div>
  </div>

  <form method="POST" class="max-w-2xl">
    <div class="glass-card rounded-2xl p-8 space-y-6">
      <h2 class="text-lg font-bold text-slate-800 border-b border-white/60 pb-3">Información del Perfil</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Nombre(s)</label>
          <input type="text" name="firstName" value={String(u.firstName)} required
            class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 shadow-sm"/>
        </div>

        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Apellidos</label>
          <input type="text" name="lastName" value={String(u.lastName)} required
            class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 shadow-sm"/>
        </div>

        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Correo Electrónico</label>
          <input type="email" name="email" value={String(u.email)} required
            class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 shadow-sm"/>
        </div>

        <div class="md:col-span-2">
          <label class="block text-sm font-semibold text-slate-700 mb-1.5 ml-1">Rol en el Sistema</label>
          <select name="roleId" class="w-full bg-white/50 border border-slate-200/60 rounded-xl px-4 py-3 text-slate-800 focus:outline-none focus:ring-2 focus:ring-teal-500 shadow-sm">
            {roles.map(r => (
              <option value={String(r.roleId)} selected={r.roleId === u.roleId}>{r.roleName}</option>
            ))}
          </select>
          <p class="text-xs text-amber-600 mt-1 ml-1 font-medium">⚠️ Cambiar el rol modifica los permisos de acceso de este usuario.</p>
        </div>
      </div>

      {String(id) === String(user?.userId) && (
        <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
          <p class="text-sm text-amber-800 font-medium">Estás editando tu propio perfil. El cambio de rol puede afectar tu acceso inmediatamente.</p>
        </div>
      )}
    </div>

    <div class="flex justify-end gap-4 mt-6">
      <a href="/users" class="px-6 py-3 rounded-xl border border-slate-200 text-slate-600 font-semibold hover:bg-slate-50 transition-colors">Cancelar</a>
      <button type="submit" class="px-8 py-3 bg-gradient-to-r from-teal-500 to-emerald-500 text-white font-bold rounded-xl shadow-md hover:shadow-lg transition-all active:scale-[0.98]">
        Guardar Cambios
      </button>
    </div>
  </form>
</Layout>
