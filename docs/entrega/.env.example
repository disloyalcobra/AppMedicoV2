# ═══════════════════════════════════════════════════════════
# MEDINOTE — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# See DOCS-TECNICA.md for details on each variable.
# ═══════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────
# Provider: Turso (SQLite en la nube)
# Dashboard: https://app.turso.tech
# Owner: Service (Turso)
TURSO_DATABASE_URL="libsql://your-database-url.turso.io"
# ⚠️ SENSITIVE — Token de autenticación de Turso
TURSO_AUTH_TOKEN="your-auth-token-here"

# ── Authentication ────────────────────────────────────────
# Provider: Custom Session-based
# Owner: Developer
SESSION_SECRET="your-super-secret-key-change-this-in-production"

# ── Public Variables ──────────────────────────────────────
# (No public variables required for this application)
